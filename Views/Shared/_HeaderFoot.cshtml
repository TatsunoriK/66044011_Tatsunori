@{
    var sessionUser = Context.Session.GetString("Username");
    var sessionRole = Context.Session.GetInt32("RoleId");
}
<!DOCTYPE html>
<html lang="th">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewData["Title"] - STRIKE FORCE</title>
    <link href="https://fonts.googleapis.com/css2?family=Krub:wght@400;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">
    @RenderSection("Styles", required: false)
    <style>
        body { font-family: 'Krub', sans-serif; background: #f0f2f5; display: flex; flex-direction: column; min-height: 100vh; }
        .top-auth-bar { background: #11181e; padding: 5px 0; border-bottom: 1px solid #333; }
        .top-auth-bar a { color: #adb5bd; text-decoration: none; font-size: .8rem; margin-left: 15px; transition: .3s; }
        .top-auth-bar a:hover { color: #f39c12; }
        header { background: #fff; padding: 15px 0; border-bottom: 4px solid #f39c12; }
        .logo-img { max-height: 140px; width: auto; display: block; margin: 0 auto; transition: transform .3s; filter: drop-shadow(0 0 8px rgba(243,156,18,.3)); }
        .logo-img:hover { transform: scale(1.05); }
        .main-nav { background: #1a1a1a; box-shadow: 0 4px 10px rgba(0,0,0,.3); }
        .navbar-nav .nav-link { color: #fff !important; font-weight: 600; padding: 14px 20px !important; text-transform: uppercase; font-size: .85rem; transition: .3s; position: relative; }
        .navbar-nav .nav-link::after { content: ""; position: absolute; bottom: 0; left: 50%; width: 0; height: 3px; background: #f39c12; transition: .3s; transform: translateX(-50%); }
        .navbar-nav .nav-link:hover::after { width: 100%; }
        .navbar-nav .nav-link:hover { color: #f39c12 !important; }
        .content-wrapper { flex: 1; padding: 40px 0; }
        footer { background: #11181e; color: #ecf0f1; padding-top: 50px; border-top: 5px solid #1a1a1a; }
        footer h4 { color: #fff; font-size: 1.1rem; margin-bottom: 20px; padding-bottom: 8px; position: relative; }
        footer h4::after { content: ""; position: absolute; left: 0; bottom: 0; width: 40px; height: 2px; background: #f39c12; }
        .text-muted-custom { color: #95a5a6; text-decoration: none; transition: .3s; display: inline-block; margin-bottom: 6px; }
        .text-muted-custom:hover { color: #f39c12; }
        .copyright-bar { background: #0a0e12; padding: 16px 0; margin-top: 40px; color: #555; font-size: .85rem; }
    </style>
</head>
<body>

<div class="top-auth-bar">
    <div class="container d-flex justify-content-end align-items-center">
        @if (sessionUser != null)
        {
            <span class="text-warning fw-bold" style="font-size:.85rem; margin-left:15px;">
                <i class="fas fa-user me-1"></i> สวัสดี, @sessionUser
            </span>
            @if (sessionRole == 4)
            {
                <a asp-controller="Project" asp-action="OrderHistory">
                    <i class="fas fa-history me-1"></i> ประวัติการสั่งซื้อ
                </a>
            }
            <a asp-controller="Project" asp-action="Logout" class="text-danger">
                <i class="fas fa-sign-out-alt me-1"></i> ออกจากระบบ
            </a>
        }
        else
        {
            <a asp-controller="Project" asp-action="Login">
                <i class="fas fa-sign-in-alt me-1"></i> เข้าสู่ระบบ / สมัครสมาชิก
            </a>
        }
    </div>
</div>

<header class="text-center">
    <div class="container">
        <a asp-controller="Project" asp-action="ProductList" class="d-inline-block">
            <img src="/images/Logo.png" alt="Strike Force" class="logo-img">
        </a>
        <p class="text-warning mt-1 mb-0 fw-bold" style="letter-spacing:2px; font-size:1rem;">
            <i class="fas fa-crosshairs me-2"></i>PREMIUM BB GUN & GEAR
        </p>
    </div>
</header>

<nav class="navbar navbar-expand-lg navbar-dark main-nav sticky-top">
    <div class="container">
        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
            <span class="navbar-toggler-icon"></span>
        </button>
        <div class="collapse navbar-collapse justify-content-center" id="navbarNav">
            <ul class="navbar-nav">

                <li class="nav-item">
                    <a class="nav-link" asp-controller="Project" asp-action="ProductList">
                        <i class="fas fa-home me-1"></i> หน้าแรก
                    </a>
                </li>

                @* Customer (4) *@
                @if (sessionRole == 4)
                {
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Project" asp-action="CartPage">
                            <i class="fas fa-shopping-cart me-1"></i> ตะกร้า
                        </a>
                    </li>
                }

                @* Staff (3) *@
                @if (sessionRole == 3)
                {
                    <li class="nav-item">
                        <a class="nav-link text-warning" asp-controller="Project" asp-action="OrderManagement">
                            <i class="fas fa-clipboard-list me-1"></i> จัดการออเดอร์
                        </a>
                    </li>
                }

                @* Manager (2) *@
                @if (sessionRole == 2)
                {
                    <li class="nav-item">
                        <a class="nav-link text-warning" asp-controller="Project" asp-action="OrderManagement">
                            <i class="fas fa-clipboard-list me-1"></i> จัดการออเดอร์
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link text-warning" asp-controller="Project" asp-action="SalesReport">
                            <i class="fas fa-chart-bar me-1"></i> รายงาน
                        </a>
                    </li>
                }

                @* Admin (1) *@
                @if (sessionRole == 1)
                {
                    <li class="nav-item">
                        <a class="nav-link text-warning" asp-controller="Project" asp-action="Dashboard">
                            <i class="fas fa-tachometer-alt me-1"></i> Dashboard
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link text-warning" asp-controller="Project" asp-action="Management">
                            <i class="fas fa-users-cog me-1"></i> จัดการระบบ
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link text-warning" asp-controller="Project" asp-action="OrderManagement">
                            <i class="fas fa-clipboard-list me-1"></i> จัดการออเดอร์
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link text-warning" asp-controller="Project" asp-action="StockList">
                            <i class="fas fa-boxes me-1"></i> สต็อก
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link text-warning" asp-controller="Project" asp-action="SalesReport">
                            <i class="fas fa-chart-bar me-1"></i> รายงาน
                        </a>
                    </li>
                }

            </ul>
        </div>
    </div>
</nav>

<main class="container content-wrapper">
    @RenderBody()
</main>

<footer>
    <div class="container">
        <div class="row g-4">
            <div class="col-lg-4">
                <h4 class="fw-bold">STRIKE FORCE SHOP</h4>
                <p class="small">ศูนย์รวมปืนบีบีกันและอุปกรณ์ยุทธวิธีระดับพรีเมียม</p>
                <ul class="list-unstyled small">
                    <li class="mb-2"><i class="fas fa-map-marker-alt me-2 text-warning"></i>123/45 ถนนยุทธวิธี กรุงเทพฯ</li>
                    <li class="mb-2"><i class="fas fa-phone-alt me-2 text-warning"></i>081-XXX-XXXX</li>
                    <li><i class="fas fa-envelope me-2 text-warning"></i>contact@strikeforce.com</li>
                </ul>
            </div>
            <div class="col-lg-2 ms-lg-auto">
                <h4 class="fw-bold">ช่วยเหลือ</h4>
                <ul class="list-unstyled small">
                    <li><a href="#" class="text-muted-custom">วิธีการสั่งซื้อ</a></li>
                    <li><a href="#" class="text-muted-custom">การจัดส่งสินค้า</a></li>
                    <li><a href="#" class="text-muted-custom">ติดต่อสอบถาม</a></li>
                </ul>
            </div>
            <div class="col-lg-3">
                <h4 class="fw-bold">การชำระเงิน</h4>
                <div class="d-flex gap-3 fs-2" style="color:#555;">
                    <i class="fab fa-cc-visa"></i>
                    <i class="fab fa-cc-mastercard"></i>
                    <i class="fas fa-university"></i>
                    <i class="fas fa-qrcode"></i>
                </div>
            </div>
        </div>
    </div>
    <div class="copyright-bar text-center">
        &copy; 2026 STRIKE FORCE TACTICAL. All Rights Reserved.
    </div>
</footer>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
@RenderSection("Scripts", required: false)
</body>
</html>
