@model IEnumerable<_66044011_Tatsunori.Models.Order>
@{
    ViewData["Title"] = "จัดการออเดอร์";
}

@section Styles {
    <link rel="stylesheet" href="~/css/orderManagement.css" asp-append-version="true">
}

<div class="om-wrapper">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold mb-0"><i class="fas fa-clipboard-list me-2"></i>จัดการออเดอร์</h2>
            <small class="text-muted">ตรวจสอบและอัปเดตสถานะการสั่งซื้อ</small>
        </div>
    </div>


    <div class="d-flex flex-row flex-wrap gap-3 mb-4">
        <div class="bg-white rounded-3 border px-4 py-3 text-center shadow-sm">
            <div class="fs-3 fw-bold lh-1">@ViewBag.AllCount</div>
            <div class="small text-muted text-uppercase mt-1">ทั้งหมด</div>
        </div>
        <div class="bg-white rounded-3 border px-4 py-3 text-center shadow-sm">
            <div class="fs-3 fw-bold lh-1 text-warning">@ViewBag.PendingCount</div>
            <div class="small text-muted text-uppercase mt-1">Pending</div>
        </div>
        <div class="bg-white rounded-3 border px-4 py-3 text-center shadow-sm">
            <div class="fs-3 fw-bold lh-1 text-success">@ViewBag.PaidCount</div>
            <div class="small text-muted text-uppercase mt-1">Paid</div>
        </div>
        <div class="bg-white rounded-3 border px-4 py-3 text-center shadow-sm">
            <div class="fs-3 fw-bold lh-1 text-info">@ViewBag.ShippedCount</div>
            <div class="small text-muted text-uppercase mt-1">Shipped</div>
        </div>
        <div class="bg-white rounded-3 border px-4 py-3 text-center shadow-sm">
            <div class="fs-3 fw-bold lh-1 text-danger">@ViewBag.CancelCount</div>
            <div class="small text-muted text-uppercase mt-1">Cancelled</div>
        </div>
    </div>

    <div class="d-flex flex-wrap gap-2 mb-4">
        <a asp-action="OrderManagement" asp-controller="Project"
           class="btn btn-sm rounded-pill @(ViewBag.StatusFilter == null ? "btn-dark" : "btn-outline-secondary")">
            ทั้งหมด <span class="badge bg-secondary ms-1 rounded-pill">@ViewBag.AllCount</span>
        </a>
        <a asp-action="OrderManagement" asp-controller="Project" asp-route-status="Pending"
           class="btn btn-sm rounded-pill @(ViewBag.StatusFilter == "Pending" ? "btn-dark" : "btn-outline-secondary")">
            Pending <span class="badge bg-secondary ms-1 rounded-pill">@ViewBag.PendingCount</span>
        </a>
        <a asp-action="OrderManagement" asp-controller="Project" asp-route-status="Paid"
           class="btn btn-sm rounded-pill @(ViewBag.StatusFilter == "Paid" ? "btn-dark" : "btn-outline-secondary")">
            Paid <span class="badge bg-secondary ms-1 rounded-pill">@ViewBag.PaidCount</span>
        </a>
        <a asp-action="OrderManagement" asp-controller="Project" asp-route-status="Shipped"
           class="btn btn-sm rounded-pill @(ViewBag.StatusFilter == "Shipped" ? "btn-dark" : "btn-outline-secondary")">
            Shipped <span class="badge bg-secondary ms-1 rounded-pill">@ViewBag.ShippedCount</span>
        </a>
        <a asp-action="OrderManagement" asp-controller="Project" asp-route-status="Cancelled"
           class="btn btn-sm rounded-pill @(ViewBag.StatusFilter == "Cancelled" ? "btn-dark" : "btn-outline-secondary")">
            Cancelled <span class="badge bg-secondary ms-1 rounded-pill">@ViewBag.CancelCount</span>
        </a>
    </div>

    <div class="card border-0 shadow-sm rounded-3 overflow-hidden">
        <table class="table table-hover align-middle mb-0">
            <thead class="table-dark">
                <tr>
                    <th>#</th>
                    <th>วันที่</th>
                    <th>ลูกค้า</th>
                    <th>รายการสินค้า</th>
                    <th>ที่อยู่จัดส่ง</th>
                    <th class="text-end">ยอด</th>
                    <th class="text-center">สถานะ</th>
                    <th class="text-center">อัปเดต</th>
                </tr>
            </thead>
            <tbody>
            @foreach (var order in Model)
            {
                <tr>
                    <td class="fw-bold text-muted">#@order.OrderId</td>
                    <td class="text-muted small">@order.OrderDate?.ToString("dd/MM/yy HH:mm")</td>
                    <td>
                        <div class="fw-semibold">@(order.User?.FullName ?? order.User?.Username)</div>
                        <div class="text-muted small">@order.User?.Email</div>
                    </td>
                    <td>
                        @foreach (var d in order.Orderdetails.Take(2))
                        {
                            <div class="items-list">• @d.PidNavigation?.Pname x@(d.Qty)</div>
                        }
                        @if (order.Orderdetails.Count > 2)
                        {
                            <div class="items-list text-primary small">+@(order.Orderdetails.Count - 2) รายการ</div>
                        }
                    </td>
                    <td class="small text-muted" style="max-width:160px;">
                        @if (!string.IsNullOrEmpty(order.ShippingAddress))
                        {
                            <span title="@order.ShippingAddress">
                                <i class="fas fa-map-marker-alt me-1 text-warning"></i>
                                @(order.ShippingAddress.Length > 35
                                    ? order.ShippingAddress[..35] + "…"
                                    : order.ShippingAddress)
                            </span>
                        }
                        else { <span>-</span> }
                    </td>
                    <td class="text-end">
                        <div class="fw-bold text-primary">฿@order.TotalAmount.ToString("N0")</div>
                        @if (order.DiscountAmount > 0)
                        {
                            <div class="discount-tag">
                                <i class="fas fa-tag me-1"></i>-฿@order.DiscountAmount.ToString("N0")
                                @if (!string.IsNullOrEmpty(order.CouponCode))
                                {
                                    <span class="ms-1 badge bg-warning text-dark" style="font-size:.65rem;">@order.CouponCode</span>
                                }
                            </div>
                        }
                    </td>
                    <td class="text-center">
                        <span class="om-status-badge badge-@order.Status">@order.Status</span>
                    </td>
                    <td class="text-center">
                        <div class="d-flex gap-1 justify-content-center flex-wrap">
                        @if (order.Status == "Pending")
                        {
                            <form asp-action="UpdateOrderStatus" asp-controller="Project" method="post">
                                <input type="hidden" name="orderId" value="@order.OrderId" />
                                <input type="hidden" name="newStatus" value="Paid" />
                                <button type="submit" class="btn btn-sm" style="background:#d1fae5;color:#065f46;border:none;">
                                    <i class="fas fa-check me-1"></i>Paid
                                </button>
                            </form>
                            <form asp-action="UpdateOrderStatus" asp-controller="Project" method="post">
                                <input type="hidden" name="orderId" value="@order.OrderId" />
                                <input type="hidden" name="newStatus" value="Cancelled" />
                                <button type="submit" class="btn btn-sm" style="background:#fee2e2;color:#991b1b;border:none;"
                                        onclick="return confirm('ยกเลิกออเดอร์ #@order.OrderId? สต็อกจะถูกคืนกลับอัตโนมัติ')">
                                    <i class="fas fa-times me-1"></i>Cancel
                                </button>
                            </form>
                        }
                        else if (order.Status == "Paid")
                        {
                            <form asp-action="UpdateOrderStatus" asp-controller="Project" method="post">
                                <input type="hidden" name="orderId" value="@order.OrderId" />
                                <input type="hidden" name="newStatus" value="Shipped" />
                                <button type="submit" class="btn btn-sm" style="background:#dbeafe;color:#1e40af;border:none;">
                                    <i class="fas fa-truck me-1"></i>Ship
                                </button>
                            </form>
                            <form asp-action="UpdateOrderStatus" asp-controller="Project" method="post">
                                <input type="hidden" name="orderId" value="@order.OrderId" />
                                <input type="hidden" name="newStatus" value="Cancelled" />
                                <button type="submit" class="btn btn-sm" style="background:#fee2e2;color:#991b1b;border:none;"
                                        onclick="return confirm('ยกเลิกออเดอร์ #@order.OrderId? สต็อกจะถูกคืนกลับอัตโนมัติ')">
                                    <i class="fas fa-times me-1"></i>Cancel
                                </button>
                            </form>
                        }
                        else
                        {
                            <span class="text-muted small">—</span>
                        }
                        </div>
                    </td>
                </tr>
            }
            </tbody>
        </table>
    </div>
</div>
