@{
    ViewData["Title"] = "Dashboard";
    var alertStocks  = (IEnumerable<_66044011_Tatsunori.Models.Productstock>)ViewBag.AlertStocks;
    decimal totalRev = (decimal)ViewBag.TotalRevenue;
    decimal monthRev = (decimal)ViewBag.MonthRevenue;
}

@section Styles {
    <link rel="stylesheet" href="~/css/dashboard.css" asp-append-version="true">
}

<div class="dash-wrapper">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold mb-0"><i class="fas fa-tachometer-alt me-2"></i>Admin Dashboard</h2>
            <small class="text-muted">ภาพรวมระบบ ณ @DateTime.Now.ToString("dd/MM/yyyy HH:mm")</small>
        </div>
    </div>

    <div class="kpi-grid">
        <div class="kpi-card">
            <i class="fas fa-users kpi-icon"></i>
            <div class="kpi-val text-primary">@ViewBag.TotalUsers</div>
            <div class="kpi-lbl">ผู้ใช้งานทั้งหมด</div>
        </div>
        <div class="kpi-card">
            <i class="fas fa-box kpi-icon"></i>
            <div class="kpi-val text-success">@ViewBag.TotalProducts</div>
            <div class="kpi-lbl">สินค้าทั้งหมด</div>
        </div>
        <div class="kpi-card">
            <i class="fas fa-shopping-bag kpi-icon"></i>
            <div class="kpi-val">@ViewBag.TotalOrders</div>
            <div class="kpi-lbl">ออเดอร์ทั้งหมด</div>
            @if ((int)ViewBag.PendingOrders > 0)
            {
                <div class="kpi-sub text-warning"><i class="fas fa-clock me-1"></i>รอดำเนินการ @ViewBag.PendingOrders รายการ</div>
            }
        </div>
        <div class="kpi-card">
            <i class="fas fa-dollar-sign kpi-icon"></i>
            <div class="kpi-val kpi-revenue">฿@totalRev.ToString("N0")</div>
            <div class="kpi-lbl">รายได้รวม</div>
            <div class="kpi-sub text-success">เดือนนี้: ฿@monthRev.ToString("N0")</div>
        </div>
        <div class="kpi-card">
            <i class="fas fa-exclamation-triangle kpi-icon"></i>
            <div class="kpi-val text-danger">@ViewBag.OutOfStock</div>
            <div class="kpi-lbl">สินค้าหมดสต็อก</div>
            <div class="kpi-sub text-warning">เหลือน้อย: @ViewBag.LowStock รายการ</div>
        </div>
    </div>

    <div class="row g-4">
        <div class="col-lg-7">
            <div class="section-card">
                <div class="section-head">
                    <span><i class="fas fa-clock me-2"></i>ออเดอร์ล่าสุด</span>
                    <a asp-action="OrderManagement" asp-controller="Project">ดูทั้งหมด →</a>
                </div>
                <table class="dash-table">
                    <thead><tr><th>#</th><th>ลูกค้า</th><th>วันที่</th><th class="text-end">ยอด</th><th class="text-center">สถานะ</th></tr></thead>
                    <tbody>
                    @foreach (var o in (dynamic)ViewBag.RecentOrders)
                    {
                        <tr>
                            <td class="fw-bold">#@o.OrderId</td>
                            <td>@(o.User?.FullName ?? o.User?.Username ?? "-")</td>
                            <td class="text-muted small">@o.OrderDate?.ToString("dd/MM/yy HH:mm")</td>
                            <td class="text-end fw-bold text-primary">฿@o.TotalAmount.ToString("N0")</td>
                            <td class="text-center"><span class="status-pill pill-@o.Status">@o.Status</span></td>
                        </tr>
                    }
                    </tbody>
                </table>
            </div>
        </div>

        <div class="col-lg-5">
            <div class="section-card mb-4">
                <div class="section-head">
                    <span><i class="fas fa-trophy me-2"></i>สินค้าขายดี</span>
                    <a asp-action="SalesReport" asp-controller="Project">ดูรายงาน →</a>
                </div>
                <div class="p-3">
                @{
                    var tops   = (dynamic)ViewBag.TopProducts;
                    int maxQty = 0;
                    foreach (var t in tops) { if ((int)t.Qty > maxQty) maxQty = (int)t.Qty; }
                }
                @foreach (var t in tops)
                {
                    int pct = maxQty > 0 ? (int)((decimal)(int)t.Qty / maxQty * 100) : 0;
                    <div class="mb-3">
                        <div class="d-flex justify-content-between">
                            <span class="small fw-semibold">@t.Name</span>
                            <span class="small text-muted">@t.Qty ชิ้น</span>
                        </div>
                        <div class="bar-bg"><div class="bar-fg" style="width:@pct%"></div></div>
                    </div>
                }
                </div>
            </div>

            @if (alertStocks.Any())
            {
                <div class="section-card">
                    <div class="section-head">
                        <span><i class="fas fa-bell me-2"></i>แจ้งเตือนสต็อก</span>
                        <a asp-action="StockList" asp-controller="Project">จัดการ →</a>
                    </div>
                    @foreach (var s in alertStocks)
                    {
                        var qty  = s.Quantity ?? 0;
                        var dot  = qty <= 0 ? "bg-danger" : "bg-warning";
                        var txt  = qty <= 0 ? "text-danger" : "text-warning";
                        var lbl  = qty <= 0 ? "หมด" : $"เหลือ {qty}";
                        <div class="alert-item">
                            <div class="alert-dot @dot"></div>
                            <span class="flex-grow-1 small">@s.PidNavigation?.Pname</span>
                            <span class="fw-bold @txt small">@lbl</span>
                        </div>
                    }
                </div>
            }
        </div>
    </div>
</div>
