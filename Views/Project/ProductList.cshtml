@model IEnumerable<_66044011_Tatsunori.Models.Product>
@{
    Layout = "_HeaderFoot";
    ViewData["Title"] = "สินค้าทั้งหมด";
}

@section Styles {
<style>
    .filter-sidebar {
        background: #fff;
        padding: 24px;
        border-radius: 12px;
        border: 1px solid #e0e0e0;
        box-shadow: 0 2px 8px rgba(0,0,0,.05);
        position: sticky;
        top: 80px;
    }
    .filter-sidebar h5 {
        font-weight: 700;
        font-size: 1rem;
        border-bottom: 2px solid #f0f0f0;
        padding-bottom: 10px;
        margin-bottom: 18px;
        color: #1a1a1a;
    }
    .filter-label {
        font-size: .8rem;
        font-weight: 600;
        color: #6c757d;
        text-transform: uppercase;
        margin-bottom: 8px;
        display: block;
    }
    /* Product Card */
    .product-card {
        background: #fff;
        border-radius: 12px;
        overflow: hidden;
        transition: all .3s ease;
        border: 1px solid #eee;
        height: 100%;
        display: flex;
        flex-direction: column;
    }
    .product-card:hover {
        transform: translateY(-6px);
        box-shadow: 0 12px 24px rgba(0,0,0,.1);
    }
    .product-img-wrap {
        background: #f8f9fa;
        height: 200px;
        display: flex;
        align-items: center;
        justify-content: center;
        position: relative;
        color: #dee2e6;
    }
    .stock-badge {
        position: absolute;
        top: 10px;
        right: 10px;
        font-size: .7rem;
        font-weight: 700;
        padding: 4px 10px;
        border-radius: 20px;
    }
    .product-body {
        padding: 18px;
        flex: 1;
        display: flex;
        flex-direction: column;
    }
    .brand-tag {
        font-size: .72rem;
        color: #95a5a6;
        text-transform: uppercase;
        letter-spacing: 1px;
        margin-bottom: 4px;
    }
    .product-name {
        font-weight: 600;
        font-size: 1rem;
        color: #2d3436;
        margin-bottom: 6px;
        flex: 1;
    }
    .product-price {
        font-size: 1.35rem;
        font-weight: 700;
        color: #0d6efd;
        margin-bottom: 14px;
    }
    .btn-cart {
        background: #1a1a1a;
        color: #fff;
        border: none;
        padding: 10px;
        border-radius: 8px;
        font-weight: 600;
        width: 100%;
        transition: .2s;
        cursor: pointer;
    }
    .btn-cart:hover { background: #f39c12; color: #1a1a1a; }
    .btn-cart:disabled { background: #ccc; cursor: not-allowed; }
    .no-product {
        text-align: center;
        padding: 80px 20px;
        color: #adb5bd;
    }
</style>
}

<div class="container-fluid py-4 px-lg-5">
<div class="row g-4">

    {{!-- ── SIDEBAR ── --}}
    <aside class="col-lg-3">
        <div class="filter-sidebar">
            <h5><i class="fas fa-filter me-2"></i>กรองสินค้า</h5>
            <form method="get" asp-action="ProductList">
                {{!-- ค้นหา --}}
                <div class="mb-3">
                    <span class="filter-label">ค้นหา</span>
                    <input type="text" name="search" class="form-control form-control-sm"
                           placeholder="ชื่อสินค้า..." value="@ViewBag.Search" />
                </div>
                {{!-- ประเภท --}}
                <div class="mb-3">
                    <span class="filter-label">ประเภทสินค้า</span>
                    <select name="catId" class="form-select form-select-sm">
                        <option value="">-- ทั้งหมด --</option>
                        @foreach (var c in (IEnumerable<_66044011_Tatsunori.Models.Category>)ViewBag.Categories)
                        {
                            <option value="@c.CatId" selected="@(ViewBag.CatId != null && ViewBag.CatId == c.CatId)">
                                @c.CatName
                            </option>
                        }
                    </select>
                </div>
                {{!-- แบรนด์ --}}
                <div class="mb-3">
                    <span class="filter-label">ยี่ห้อ</span>
                    <select name="brandId" class="form-select form-select-sm">
                        <option value="">-- ทั้งหมด --</option>
                        @foreach (var b in (IEnumerable<_66044011_Tatsunori.Models.Brand>)ViewBag.Brands)
                        {
                            <option value="@b.BrandId" selected="@(ViewBag.BrandId != null && ViewBag.BrandId == b.BrandId)">
                                @b.BrandName
                            </option>
                        }
                    </select>
                </div>
                {{!-- ราคา --}}
                <div class="mb-3">
                    <span class="filter-label">ช่วงราคา (฿)</span>
                    <div class="d-flex gap-2">
                        <input type="number" name="minPrice" class="form-control form-control-sm"
                               placeholder="ต่ำสุด" value="@ViewBag.MinPrice" min="0" />
                        <input type="number" name="maxPrice" class="form-control form-control-sm"
                               placeholder="สูงสุด" value="@ViewBag.MaxPrice" min="0" />
                    </div>
                </div>
                {{!-- เรียงลำดับ --}}
                <div class="mb-4">
                    <span class="filter-label">เรียงโดย</span>
                    <select name="sort" class="form-select form-select-sm">
                        <option value="">ค่าเริ่มต้น</option>
                        <option value="price_asc"  selected="@(ViewBag.Sort == "price_asc")">ราคา ต่ำ → สูง</option>
                        <option value="price_desc" selected="@(ViewBag.Sort == "price_desc")">ราคา สูง → ต่ำ</option>
                    </select>
                </div>
                <button type="submit" class="btn btn-dark btn-sm w-100">
                    <i class="fas fa-search me-1"></i>ค้นหา
                </button>
                <a asp-action="ProductList" class="btn btn-outline-secondary btn-sm w-100 mt-2">
                    <i class="fas fa-undo me-1"></i>ล้างตัวกรอง
                </a>
            </form>
        </div>
    </aside>

    {{!-- ── PRODUCT GRID ── --}}
    <main class="col-lg-9">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <div>
                <h2 class="fw-bold mb-0">สินค้าทั้งหมด</h2>
                <small class="text-muted">พบ @Model.Count() รายการ</small>
            </div>
            @if (ViewBag.RoleId != null && (int)ViewBag.RoleId <= 2)
            {
                <a asp-action="Management" class="btn btn-sm btn-outline-dark">
                    <i class="fas fa-users-cog me-1"></i>จัดการระบบ
                </a>
            }
        </div>

        @if (TempData["CartMsg"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show py-2">
                <i class="fas fa-check-circle me-1"></i> @TempData["CartMsg"]
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }

        @if (!Model.Any())
        {
            <div class="no-product">
                <i class="fas fa-box-open fa-3x mb-3"></i>
                <p>ไม่พบสินค้าที่ตรงกับเงื่อนไข</p>
            </div>
        }
        else
        {
            <div class="row row-cols-1 row-cols-md-2 row-cols-xl-3 g-4">
            @foreach (var p in Model)
            {
                var inStock = p.Productstock?.Quantity ?? 0;
                <div class="col">
                    <div class="product-card">
                        <div class="product-img-wrap">
                            @if (inStock <= 0)
                            {
                                <span class="stock-badge bg-danger text-white">หมด</span>
                            }
                            else if (inStock <= 5)
                            {
                                <span class="stock-badge bg-warning text-dark">เหลือน้อย</span>
                            }
                            else
                            {
                                <span class="stock-badge bg-success text-white">มีสินค้า</span>
                            }
                            <i class="fas fa-gun fa-4x opacity-25"></i>
                        </div>
                        <div class="product-body">
                            <div class="brand-tag">@(p.Brand?.BrandName ?? "—") · @(p.Cat?.CatName ?? "—")</div>
                            <div class="product-name">@p.Pname</div>
                            <div class="product-price">฿@p.Price.ToString("N0")</div>
                            @if (ViewBag.Username != null)
                            {
                                <form asp-action="AddToCart" method="post">
                                    <input type="hidden" name="pid" value="@p.Pid" />
                                    <input type="hidden" name="qty" value="1" />
                                    <button type="submit" class="btn-cart" @(inStock <= 0 ? "disabled" : "")>
                                        <i class="fas fa-shopping-cart me-2"></i>
                                        @(inStock <= 0 ? "สินค้าหมด" : "เพิ่มลงตะกร้า")
                                    </button>
                                </form>
                            }
                            else
                            {
                                <a asp-action="Login" class="btn-cart text-center d-block text-decoration-none">
                                    <i class="fas fa-sign-in-alt me-2"></i>Login เพื่อซื้อ
                                </a>
                            }
                        </div>
                    </div>
                </div>
            }
            </div>
        }
    </main>

</div>
</div>
