@model _66044011_Tatsunori.Models.User
@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Edit Employee - @Model.FullName</title>
    
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/css/login.css" asp-append-version="true">
   
</head>

<body>
    <div class="manage-wrapper">
        <div class="management-header" style="margin-bottom: 30px;">
            <div class="title-section">
                <h2 class="main-title">Edit Employee Information</h2>
                <p class="sub-title">ปรับปรุงข้อมูลพนักงาน <span class="id-tag">#@Model.Id</span></p>
            </div>
        </div>

        <div class="form-container">
            <form asp-controller="Project" asp-action="EditUser" method="post">
                <input type="hidden" asp-for="Id" />
                <input type="hidden" asp-for="Userprofile.UserId" />

                <div class="section-title">
                    <i class="bi bi-shield-lock"></i> System Credentials
                </div>
                <div class="form-row">
                    <div class="form-group">
                        <label>Username</label>
                        <input asp-for="Username" class="form-control" readonly style="background-color: #f9fafb; cursor: not-allowed;" />
                        <small style="color: #9ca3af;">Username ไม่สามารถแก้ไขได้</small>
                    </div>
                    <div class="form-group">
                        <label>Email Address</label>
                        <input asp-for="Email" type="email" class="form-control" placeholder="employee@company.com" required />
                    </div>
                </div>

                <div class="section-title" style="margin-top: 40px;">
                    <i class="bi bi-person-badge"></i> Personal Profile
                </div>
                <div class="form-group" style="margin-bottom: 20px;">
                    <label>Full Name</label>
                    <input asp-for="FullName" class="form-control" placeholder="ชื่อ-นามสกุล ภาษาไทย หรือ อังกฤษ" required />
                </div>

                <div class="form-row">
                    <div class="form-group">
                        <label>Gender</label>
                        <select asp-for="Userprofile.Gender" class="form-control">
                            <option value="">-- ระบุเพศ --</option>
                            <option value="Male">Male</option>
                            <option value="Female">Female</option>
                            <option value="Other">Other</option>
                        </select>
                    </div>
                    <div class="form-group">
                        <label>Birth Date</label>
                        <input asp-for="Userprofile.Birthday" type="date" class="form-control" />
                    </div>
                </div>

                <div class="form-row">
                    <div class="form-group">
                        <label>Telephone</label>
                        <input asp-for="Userprofile.Tel" class="form-control" placeholder="08x-xxx-xxxx" />
                    </div>
                    <div style="flex: 1;"></div> </div>

                <div class="form-group">
                    <label>Address</label>
                    <textarea asp-for="Userprofile.Address" class="form-control" placeholder="ที่อยู่ปัจจุบันสำหรับจัดส่งเอกสาร..."></textarea>
                </div>

                <div class="action-footer">
                    <a asp-action="Management" asp-controller="Project" class="btn-cancel">
                        Cancel
                    </a>
                    <button type="submit" class="btn-save">
                        <i class="bi bi-floppy"></i> Save Changes
                    </button>
                </div>
            </form>
        </div>
    </div>
</body>

</html>