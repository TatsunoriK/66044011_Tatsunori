@model _66044011_Tatsunori.Models.User
@{
    ViewData["Title"] = "แก้ไขข้อมูลพนักงาน";
}

@section Styles {
    <link rel="stylesheet" href="~/css/editUser.css" asp-append-version="true">
}

<div class="edit-wrapper">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold mb-0">Edit Employee Information</h2>
            <p class="text-muted small">ปรับปรุงข้อมูลพนักงาน <span class="id-tag">#@Model.Id</span></p>
        </div>
    </div>

    <div class="form-container">
        <form asp-controller="Project" asp-action="EditUser" method="post">
            <input type="hidden" asp-for="Id" />
            <input type="hidden" asp-for="Userprofile.UserId" />

            <div class="section-title"><i class="fas fa-shield-alt"></i> System Credentials</div>
            <div class="form-row">
                <div class="form-group">
                    <label>Username</label>
                    <input asp-for="Username" class="form-control bg-light" readonly />
                    <small class="text-muted">Username ไม่สามารถแก้ไขได้</small>
                </div>
                <div class="form-group">
                    <label>Email</label>
                    <input asp-for="Email" type="email" class="form-control" placeholder="employee@company.com" required />
                </div>
            </div>

            <div class="section-title mt-4"><i class="fas fa-user"></i> Personal Profile</div>
            <div class="form-group mb-3">
                <label>Full Name</label>
                <input asp-for="FullName" class="form-control" placeholder="ชื่อ-นามสกุล" required />
            </div>

            <div class="form-row">
                <div class="form-group">
                    <label>Gender</label>
                    <select asp-for="Userprofile.Gender" class="form-control">
                        <option value="">-- ระบุเพศ --</option>
                        <option value="Male">Male</option>
                        <option value="Female">Female</option>
                    </select>
                </div>
                <div class="form-group">
                    <label>Birth Date</label>
                    <input asp-for="Userprofile.Birthday" type="date" class="form-control" />
                </div>
            </div>

            <div class="form-row">
                <div class="form-group">
                    <label>Telephone</label>
                    <input asp-for="Userprofile.Tel" class="form-control" placeholder="08x-xxx-xxxx" />
                </div>
                <div class="form-group">
                    <label>Address</label>
                    <textarea asp-for="Userprofile.Address" class="form-control" placeholder="ที่อยู่ปัจจุบัน..."></textarea>
                </div>
            </div>

            <div class="action-footer">
                <a asp-action="Management" asp-controller="Project" class="btn-cancel">Cancel</a>
                <button type="submit" class="btn-save"><i class="fas fa-save me-1"></i>Save Changes</button>
            </div>
        </form>
    </div>
</div>
