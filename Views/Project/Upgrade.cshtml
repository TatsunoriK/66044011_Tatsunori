@{
    ViewData["Title"] = "Member Plan";
    var user      = ViewBag.UserData as _66044011_Tatsunori.Models.User;
    bool active   = user?.IsMember == true && user.MemberExpiry != null && user.MemberExpiry >= DateTime.Now;
    int  daysLeft = active ? (int)(user!.MemberExpiry!.Value - DateTime.Now).TotalDays + 1 : 0;
    int  myPoints = user?.Points ?? 0;
    int  pendingEarn = ViewBag.PendingEarn as int? ?? 0;
}

@section Styles {
    <link rel="stylesheet" href="~/css/upgrade.css" asp-append-version="true">
}

<div class="upgrade-wrapper">
    <h2 class="fw-bold mb-1"><i class="fas fa-crown me-2 text-warning"></i>Member Plan</h2>
    <p class="text-muted mb-4">สมัคร/ต่ออายุ Membership รับสิทธิประโยชน์พิเศษ</p>

    @if (TempData["UpgradeSuccess"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show mb-4">
            <i class="fas fa-check-circle me-1"></i> @TempData["UpgradeSuccess"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @* สถานะปัจจุบัน *@
    <div class="member-status @(active ? "active" : "inactive")">
        <div class="d-flex align-items-center gap-3">
            <div class="ms-icon">@(active ? "👑" : "🎖️")</div>
            <div>
                <div class="ms-title">@(active ? "MEMBER ACTIVE" : "ยังไม่ได้เป็นสมาชิก")</div>
                @if (active)
                {
                    <div class="small" style="opacity:.75;">หมดอายุ @user!.MemberExpiry!.Value.ToString("dd MMM yyyy")</div>
                    <div class="ms-expiry">เหลือ <span class="days-num">@daysLeft</span> วัน</div>
                }
                else
                {
                    <div class="small text-muted">สมัครวันนี้ รับสิทธิ์ทันที 30 วัน</div>
                    <div class="ms-expiry">Bronze Member (ฟรี)</div>
                }
            </div>
        </div>
    </div>

    @* แต้มสะสม *@
    <div class="plan-detail" style="margin-bottom:16px;">
        <div class="d-flex align-items-center justify-content-between flex-wrap gap-2">
            <div>
                <div class="fw-bold mb-1"><i class="fas fa-coins me-2 text-warning"></i>แต้มสะสมของฉัน</div>
                <div style="font-size:2rem;font-weight:800;color:#f39c12;line-height:1;">
                    @myPoints <small style="font-size:1rem;color:#6b7280;">แต้ม</small>
                </div>
                <div class="text-muted small mt-1">= ส่วนลด ฿@(myPoints / 10) | แลก 10 แต้ม = ฿1</div>
            </div>
            <div style="text-align:right;">
                @if (pendingEarn > 0)
                {
                    <div style="background:#fef3c7;border:1px solid #fde68a;border-radius:10px;padding:10px 14px;">
                        <div class="small fw-bold" style="color:#92400e;">
                            <i class="fas fa-clock me-1"></i>รอยืนยันชำระเงิน
                        </div>
                        <div style="font-size:1.3rem;font-weight:800;color:#d97706;">
                            +@pendingEarn แต้ม
                        </div>
                        <div class="small" style="color:#92400e;">จะได้รับเมื่อ Staff ยืนยัน Paid</div>
                    </div>
                }
                else
                {
                    <div class="text-muted small">ไม่มีแต้มรอยืนยัน</div>
                }
            </div>
        </div>
    </div>

    @* รายละเอียด Plan *@
    <div class="plan-detail">
        <h5><i class="fas fa-star me-2 text-warning"></i>STRIKE FORCE MEMBER — ฿199 / 30 วัน</h5>

        <table class="perks-table">
            <tr>
                <td><span class="perk-icon"><i class="fas fa-tag"></i></span><span class="perk-label">ส่วนลดพิเศษ</span></td>
                <td class="perk-val">฿100 / 1 ออเดอร์ต่อเดือน</td>
            </tr>
            <tr>
                <td><span class="perk-icon"><i class="fas fa-coins"></i></span><span class="perk-label">สะสมแต้ม</span></td>
                <td class="perk-val">1 แต้ม / ทุก ฿10</td>
            </tr>
            <tr>
                <td><span class="perk-icon"><i class="fas fa-exchange-alt"></i></span><span class="perk-label">แลกแต้ม</span></td>
                <td class="perk-val">10 แต้ม = ฿1</td>
            </tr>
            <tr>
                <td><span class="perk-icon"><i class="fas fa-bolt"></i></span><span class="perk-label">Flash Sale</span></td>
                <td class="perk-val">เข้าถึงก่อนใคร</td>
            </tr>
            <tr>
                <td><span class="perk-icon"><i class="fas fa-sync"></i></span><span class="perk-label">ต่ออายุ</span></td>
                <td class="perk-val">ต่อได้ไม่จำกัด</td>
            </tr>
        </table>

        <div class="points-rate-box">
            <div class="rate-title"><i class="fas fa-coins me-1"></i>อัตราการได้รับแต้ม</div>
            <div class="rate-row"><span>ทุก ฿10 ที่ใช้จ่าย</span><span><strong>+1 แต้ม</strong></span></div>
            <div class="rate-row"><span>ออเดอร์ ฿500</span><span><strong>+50 แต้ม</strong></span></div>
            <div class="rate-row"><span>ออเดอร์ ฿1,000</span><span><strong>+100 แต้ม</strong></span></div>
            <div class="rate-row"><span>ออเดอร์ ฿5,000</span><span><strong>+500 แต้ม</strong></span></div>
            <div class="rate-row" style="border-top:1px dashed #f0d9b5;margin-top:6px;padding-top:6px;">
                <span>แลกใช้</span><span><strong>10 แต้ม = ลด ฿1</strong></span>
            </div>
        </div>

        @if (!active)
        {
            <button class="btn-buy" onclick="openConfirm()">
                <i class="fas fa-crown me-2"></i>สมัคร Member — ฿199
            </button>
        }
        else
        {
            <button class="btn-renew" onclick="openConfirm()">
                <i class="fas fa-sync me-2"></i>ต่ออายุอีก 30 วัน — ฿199
            </button>
        }
    </div>
</div>

@* Confirm & Pay Modal *@
<div class="modal-overlay" id="confirmModal">
    <div class="confirm-modal">
        <h5><i class="fas fa-receipt me-2 text-warning"></i>ยืนยันการสั่งซื้อ</h5>

        <div class="order-summary">
            <div class="sum-row">
                <span>STRIKE FORCE MEMBER (30 วัน)</span>
                <span>฿199</span>
            </div>
            <div class="sum-row discount">
                <span><i class="fas fa-tag me-1"></i>ส่วนลดที่จะได้รับ/เดือน</span>
                <span>-฿100</span>
            </div>
            <div class="sum-row">
                <span>แต้มสะสม (1 แต้ม/฿10)</span>
                <span>ทุกออเดอร์</span>
            </div>
            <div class="sum-row">
                <span>ยอดที่ต้องชำระ</span>
                <span>฿199</span>
            </div>
        </div>

        <div class="pay-title"><i class="fas fa-credit-card me-1"></i>เลือกวิธีชำระเงิน</div>
        <div class="pay-grid">
            <button type="button" class="pay-option" onclick="pickPay(this)">
                <i class="fab fa-cc-visa"></i>Visa
            </button>
            <button type="button" class="pay-option" onclick="pickPay(this)">
                <i class="fab fa-cc-mastercard"></i>Mastercard
            </button>
            <button type="button" class="pay-option" onclick="pickPay(this)">
                <i class="fas fa-university"></i>โอนเงิน
            </button>
            <button type="button" class="pay-option" onclick="pickPay(this)">
                <i class="fas fa-qrcode"></i>QR Code
            </button>
        </div>

        <div class="pay-confirm-msg" id="payConfirmMsg">
            <i class="fas fa-check-circle me-1"></i>เลือกวิธีชำระเงินแล้ว — กดยืนยันเพื่อเปิดใช้งาน
        </div>

        <form asp-action="UpgradePlan" asp-controller="Project" method="post">
            <button type="submit" class="btn-confirm" id="confirmBtn" disabled>
                <i class="fas fa-crown me-1"></i>ยืนยัน — เปิดใช้งาน Member
            </button>
        </form>
        <button type="button" class="btn-modal-cancel" onclick="closeModal()">ยกเลิก</button>
    </div>
</div>

@section Scripts {
<script>
function openConfirm() {
    document.getElementById('payConfirmMsg').classList.remove('show');
    document.getElementById('confirmBtn').disabled = true;
    document.querySelectorAll('.pay-option').forEach(function(b){ b.classList.remove('picked'); });
    document.getElementById('confirmModal').classList.add('show');
}
function closeModal() {
    document.getElementById('confirmModal').classList.remove('show');
}
function pickPay(btn) {
    document.querySelectorAll('.pay-option').forEach(function(b){ b.classList.remove('picked'); });
    btn.classList.add('picked');
    document.getElementById('payConfirmMsg').classList.add('show');
    document.getElementById('confirmBtn').disabled = false;
}
document.getElementById('confirmModal').addEventListener('click', function(e){
    if (e.target === this) closeModal();
});
</script>
}
