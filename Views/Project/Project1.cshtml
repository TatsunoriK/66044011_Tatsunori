@model IEnumerable<_66044011_Tatsunori.Models.Product>
@{
    Layout = "_HeaderFoot";
    ViewData["Title"] = "สินค้าทั้งหมด";
}

@section Styles {
    <link rel="stylesheet" href="~/css/project1.css" asp-append-version="true">
}

<div class="row g-4">
    <aside class="col-lg-3">
        <div class="filter-sidebar">
            <h5><i class="fas fa-filter me-2"></i>กรองสินค้า</h5>
            <form method="get" asp-action="ProductList" asp-controller="Project">
                <div class="mb-3">
                    <span class="filter-label">ค้นหา</span>
                    <input type="text" name="search" class="form-control form-control-sm" placeholder="ชื่อสินค้า..." value="@ViewBag.Search" />
                </div>
                <div class="mb-3">
                    <span class="filter-label">ประเภทสินค้า</span>
                    <select name="catId" class="form-select form-select-sm">
                        <option value="">-- ทั้งหมด --</option>
                        @foreach (var c in (IEnumerable<_66044011_Tatsunori.Models.Category>)ViewBag.Categories)
                        {
                            if (ViewBag.CatId != null && (int)ViewBag.CatId == c.CatId)
                            { <option value="@c.CatId" selected="selected">@c.CatName</option> }
                            else
                            { <option value="@c.CatId">@c.CatName</option> }
                        }
                    </select>
                </div>
                <div class="mb-3">
                    <span class="filter-label">ยี่ห้อ</span>
                    <select name="brandId" class="form-select form-select-sm">
                        <option value="">-- ทั้งหมด --</option>
                        @foreach (var b in (IEnumerable<_66044011_Tatsunori.Models.Brand>)ViewBag.Brands)
                        {
                            if (ViewBag.BrandId != null && (int)ViewBag.BrandId == b.BrandId)
                            { <option value="@b.BrandId" selected="selected">@b.BrandName</option> }
                            else
                            { <option value="@b.BrandId">@b.BrandName</option> }
                        }
                    </select>
                </div>
                <div class="mb-3">
                    <span class="filter-label">ช่วงราคา (฿)</span>
                    <div class="d-flex gap-2">
                        <input type="number" name="minPrice" class="form-control form-control-sm" placeholder="ต่ำสุด" value="@ViewBag.MinPrice" min="0" />
                        <input type="number" name="maxPrice" class="form-control form-control-sm" placeholder="สูงสุด" value="@ViewBag.MaxPrice" min="0" />
                    </div>
                </div>
                <div class="mb-4">
                    <span class="filter-label">เรียงโดย</span>
                    <select name="sort" class="form-select form-select-sm">
                        <option value="">ค่าเริ่มต้น</option>
                        @if (ViewBag.Sort == "price_asc")
                        { <option value="price_asc" selected="selected">ราคา ต่ำ - สูง</option><option value="price_desc">ราคา สูง - ต่ำ</option> }
                        else if (ViewBag.Sort == "price_desc")
                        { <option value="price_asc">ราคา ต่ำ - สูง</option><option value="price_desc" selected="selected">ราคา สูง - ต่ำ</option> }
                        else
                        { <option value="price_asc">ราคา ต่ำ - สูง</option><option value="price_desc">ราคา สูง - ต่ำ</option> }
                    </select>
                </div>
                <button type="submit" class="btn btn-dark btn-sm w-100"><i class="fas fa-search me-1"></i>ค้นหา</button>
                <a asp-action="ProductList" asp-controller="Project" class="btn btn-outline-secondary btn-sm w-100 mt-2"><i class="fas fa-undo me-1"></i>ล้างตัวกรอง</a>
            </form>
        </div>
    </aside>

    <section class="col-lg-9">
        <div class="mb-4">
            <h2 class="fw-bold mb-0">สินค้าทั้งหมด</h2>
            <small class="text-muted">พบ @Model.Count() รายการ</small>
        </div>

        @if (TempData["CartMsg"] != null)
        {
            <div class="alert alert-@(TempData["CartMsg"]!.ToString()!.Contains("เฉพาะ") ? "warning" : "success") alert-dismissible fade show py-2">
                <i class="fas fa-@(TempData["CartMsg"]!.ToString()!.Contains("เฉพาะ") ? "exclamation-triangle" : "check-circle") me-1"></i> @TempData["CartMsg"]
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }

        @if (!Model.Any())
        {
            <div class="no-product">
                <i class="fas fa-box-open fa-3x mb-3"></i>
                <p>ไม่พบสินค้าที่ตรงกับเงื่อนไข</p>
            </div>
        }
        else
        {
            <div class="row row-cols-1 row-cols-md-2 row-cols-xl-3 g-4">
            @foreach (var p in Model)
            {
                var inStock = p.Productstock?.Quantity ?? 0;
                <div class="col">
                    <div class="product-card">
                        <div class="product-img-wrap">
                            @if (inStock <= 0)
                            { <span class="stock-badge bg-danger text-white">หมด</span> }
                            else if (inStock <= 5)
                            { <span class="stock-badge bg-warning text-dark">เหลือน้อย</span> }
                            else
                            { <span class="stock-badge bg-success text-white">มีสินค้า</span> }
                            <i class="fas fa-gun fa-4x opacity-25"></i>
                        </div>
                        <div class="product-body">
                            <div class="brand-tag">@(p.Brand?.BrandName ?? "—") · @(p.Cat?.CatName ?? "—")</div>
                            <div class="product-name">@p.Pname</div>
                            <div class="product-price">฿@p.Price.ToString("N0")</div>

                            @if (ViewBag.Username != null && (int)(ViewBag.RoleId ?? 5) == 4)
                            {
                                <form asp-action="AddToCart" asp-controller="Project" method="post">
                                    <input type="hidden" name="pid" value="@p.Pid" />
                                    <input type="hidden" name="qty" value="1" />
                                    @if (inStock <= 0)
                                    { <button type="submit" class="btn-cart" disabled><i class="fas fa-times me-2"></i>สินค้าหมด</button> }
                                    else
                                    { <button type="submit" class="btn-cart"><i class="fas fa-shopping-cart me-2"></i>เพิ่มลงตะกร้า</button> }
                                </form>
                            }
                            else if (ViewBag.Username == null)
                            {
                                <a asp-action="Login" asp-controller="Project" class="btn-cart">
                                    <i class="fas fa-sign-in-alt me-2"></i>Login เพื่อซื้อ
                                </a>
                            }
                            else
                            {
                                <div class="btn-cart text-center" style="background:#6c757d; cursor:default;">
                                    <i class="fas fa-eye me-2"></i>ดูสินค้า
                                </div>
                            }
                        </div>
                    </div>
                </div>
            }
            </div>
        }
    </section>
</div>
