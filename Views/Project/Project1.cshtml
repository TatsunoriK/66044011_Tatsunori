@model IEnumerable<_66044011_Tatsunori.Models.Product>
@{
    Layout = "_HeaderFoot";
    ViewData["Title"] = "สินค้าทั้งหมด";
}

@section Styles {
<style>
    .promo-banner {
        background-color: #1a1a1a;
        color: #ffc107;
        padding: 12px 0;
        font-weight: 600;
        text-align: center;
        border-bottom: 4px solid #ffc107;
        font-size: 0.95rem;
    }
    .filter-sidebar {
        background: #fff;
        padding: 24px;
        border-radius: 12px;
        box-shadow: 0 4px 12px rgba(0,0,0,.05);
        border: 1px solid #e0e0e0;
        position: sticky;
        top: 80px;
    }
    .filter-group h5 {
        font-size: 1rem;
        font-weight: 700;
        margin-bottom: 18px;
        color: #1a1a1a;
        border-bottom: 2px solid #f0f0f0;
        padding-bottom: 10px;
    }
    .filter-label {
        font-size: .8rem;
        font-weight: 600;
        color: #6c757d;
        text-transform: uppercase;
        margin-bottom: 8px;
        display: block;
    }
    .product-card {
        background: #fff;
        border-radius: 12px;
        overflow: hidden;
        transition: all .3s ease;
        border: 1px solid #eee;
        height: 100%;
        display: flex;
        flex-direction: column;
    }
    .product-card:hover {
        transform: translateY(-8px);
        box-shadow: 0 12px 24px rgba(0,0,0,.1);
    }
    .product-img {
        background-color: #f8f9fa;
        height: 200px;
        display: flex;
        align-items: center;
        justify-content: center;
        position: relative;
        color: #dee2e6;
    }
    .stock-badge {
        position: absolute;
        top: 10px;
        right: 10px;
        font-size: .7rem;
        font-weight: 700;
        padding: 4px 10px;
        border-radius: 20px;
    }
    .product-info {
        padding: 18px;
        flex-grow: 1;
        display: flex;
        flex-direction: column;
    }
    .brand-label {
        font-size: .72rem;
        color: #95a5a6;
        text-transform: uppercase;
        letter-spacing: 1px;
        margin-bottom: 4px;
    }
    .product-name {
        font-size: 1rem;
        font-weight: 600;
        color: #2d3436;
        margin-bottom: 6px;
        flex: 1;
    }
    .price-text {
        font-size: 1.35rem;
        font-weight: 700;
        color: #0d6efd;
        margin-bottom: 14px;
    }
    .btn-add-cart {
        background-color: #1a1a1a;
        color: #fff;
        border: none;
        padding: 10px;
        border-radius: 8px;
        width: 100%;
        font-weight: 600;
        margin-top: auto;
        transition: .2s;
        cursor: pointer;
    }
    .btn-add-cart:hover { background-color: #ffc107; color: #1a1a1a; }
    .btn-add-cart:disabled { background: #ccc; cursor: not-allowed; }
</style>
}

<div class="promo-banner" style="margin: -40px -12px 30px -12px;">
    <i class="fas fa-bolt me-2"></i> Flash Sale: ปืนยาว AEG ลด 20% | แถมฟรี! ลูกกระสุน 1 ถุง เมื่อโอนเงินออนไลน์วันนี้
</div>

<div class="container-fluid px-lg-4">
<div class="row g-4">

    <aside class="col-lg-3">
        <div class="filter-sidebar">
            <div class="filter-group">
                <h5><i class="fas fa-filter me-2"></i>กรองสินค้า</h5>
                <form method="get" asp-action="ProductList" asp-controller="Project">

                    <div class="mb-3">
                        <span class="filter-label">ค้นหา</span>
                        <input type="text" name="search" class="form-control form-control-sm"
                               placeholder="ชื่อสินค้า..." value="@ViewBag.Search" />
                    </div>

                    <div class="mb-3">
                        <span class="filter-label">ประเภทสินค้า</span>
                        <select name="catId" class="form-select form-select-sm">
                            <option value="">-- ทั้งหมด --</option>
                            @foreach (var c in (IEnumerable<_66044011_Tatsunori.Models.Category>)ViewBag.Categories)
                            {
                                if (ViewBag.CatId != null && (int)ViewBag.CatId == c.CatId)
                                {
                                    <option value="@c.CatId" selected="selected">@c.CatName</option>
                                }
                                else
                                {
                                    <option value="@c.CatId">@c.CatName</option>
                                }
                            }
                        </select>
                    </div>

                    <div class="mb-3">
                        <span class="filter-label">ยี่ห้อ</span>
                        <select name="brandId" class="form-select form-select-sm">
                            <option value="">-- ทั้งหมด --</option>
                            @foreach (var b in (IEnumerable<_66044011_Tatsunori.Models.Brand>)ViewBag.Brands)
                            {
                                if (ViewBag.BrandId != null && (int)ViewBag.BrandId == b.BrandId)
                                {
                                    <option value="@b.BrandId" selected="selected">@b.BrandName</option>
                                }
                                else
                                {
                                    <option value="@b.BrandId">@b.BrandName</option>
                                }
                            }
                        </select>
                    </div>

                    <div class="mb-3">
                        <span class="filter-label">ช่วงราคา (฿)</span>
                        <div class="d-flex gap-2">
                            <input type="number" name="minPrice" class="form-control form-control-sm"
                                   placeholder="ต่ำสุด" value="@ViewBag.MinPrice" min="0" />
                            <input type="number" name="maxPrice" class="form-control form-control-sm"
                                   placeholder="สูงสุด" value="@ViewBag.MaxPrice" min="0" />
                        </div>
                    </div>

                    <div class="mb-4">
                        <span class="filter-label">เรียงโดย</span>
                        <select name="sort" class="form-select form-select-sm">
                            <option value="">ค่าเริ่มต้น</option>
                            @if (ViewBag.Sort == "price_asc")
                            {
                                <option value="price_asc" selected="selected">ราคา ต่ำ → สูง</option>
                                <option value="price_desc">ราคา สูง → ต่ำ</option>
                            }
                            else if (ViewBag.Sort == "price_desc")
                            {
                                <option value="price_asc">ราคา ต่ำ → สูง</option>
                                <option value="price_desc" selected="selected">ราคา สูง → ต่ำ</option>
                            }
                            else
                            {
                                <option value="price_asc">ราคา ต่ำ → สูง</option>
                                <option value="price_desc">ราคา สูง → ต่ำ</option>
                            }
                        </select>
                    </div>

                    <button type="submit" class="btn btn-dark btn-sm w-100">
                        <i class="fas fa-search me-1"></i>ค้นหา
                    </button>
                    <a asp-action="ProductList" asp-controller="Project"
                       class="btn btn-outline-secondary btn-sm w-100 mt-2">
                        <i class="fas fa-undo me-1"></i>ล้างตัวกรอง
                    </a>

                </form>
            </div>
        </div>
    </aside>

    <main class="col-lg-9">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <div>
                <h2 class="fw-bold mb-0">สินค้าทั้งหมด</h2>
                <small class="text-muted">พบ @Model.Count() รายการ</small>
            </div>
            @if (ViewBag.RoleId != null && (int)ViewBag.RoleId <= 2)
            {
                <a asp-action="Management" asp-controller="Project" class="btn btn-sm btn-outline-dark">
                    <i class="fas fa-users-cog me-1"></i>จัดการระบบ
                </a>
            }
        </div>

        @if (TempData["CartMsg"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show py-2">
                <i class="fas fa-check-circle me-1"></i> @TempData["CartMsg"]
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }

        @if (!Model.Any())
        {
            <div class="text-center py-5 text-muted">
                <i class="fas fa-box-open fa-3x mb-3"></i>
                <p>ไม่พบสินค้าที่ตรงกับเงื่อนไข</p>
            </div>
        }
        else
        {
            <div class="row row-cols-1 row-cols-md-2 row-cols-xl-3 g-4">
            @foreach (var p in Model)
            {
                var inStock = p.Productstock?.Quantity ?? 0;
                <div class="col">
                    <div class="product-card">
                        <div class="product-img">
                            @if (inStock <= 0)
                            {
                                <span class="stock-badge bg-danger text-white">หมด</span>
                            }
                            else if (inStock <= 5)
                            {
                                <span class="stock-badge bg-warning text-dark">เหลือน้อย</span>
                            }
                            else
                            {
                                <span class="stock-badge bg-success text-white">มีสินค้า</span>
                            }
                            <i class="fas fa-gun fa-4x opacity-25"></i>
                        </div>
                        <div class="product-info">
                            <div class="brand-label">
                                @(p.Brand?.BrandName ?? "—") · @(p.Cat?.CatName ?? "—")
                            </div>
                            <div class="product-name">@p.Pname</div>
                            <div class="price-text">฿@p.Price.ToString("N0")</div>

                            @if (ViewBag.Username != null)
                            {
                                <form asp-action="AddToCart" asp-controller="Project" method="post">
                                    <input type="hidden" name="pid" value="@p.Pid" />
                                    <input type="hidden" name="qty" value="1" />
                                    @if (inStock <= 0)
                                    {
                                        <button type="submit" class="btn-add-cart" disabled>
                                            <i class="fas fa-shopping-cart me-2"></i>สินค้าหมด
                                        </button>
                                    }
                                    else
                                    {
                                        <button type="submit" class="btn-add-cart">
                                            <i class="fas fa-shopping-cart me-2"></i>เพิ่มลงตะกร้า
                                        </button>
                                    }
                                </form>
                            }
                            else
                            {
                                <a asp-action="Login" asp-controller="Project"
                                   class="btn-add-cart text-center d-block text-decoration-none">
                                    <i class="fas fa-sign-in-alt me-2"></i>Login เพื่อซื้อ
                                </a>
                            }
                        </div>
                    </div>
                </div>
            }
            </div>
        }
    </main>

</div>
</div>