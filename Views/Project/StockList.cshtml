@model IEnumerable<_66044011_Tatsunori.Models.Productstock>
@{
    Layout = "_HeaderFoot";
    ViewData["Title"] = "จัดการสต็อกสินค้า";
}

@section Styles {
    <link rel="stylesheet" href="~/css/stockList.css" asp-append-version="true">
}

@* Confirm Modal *@
<div class="confirm-modal-overlay" id="confirmModal">
    <div class="confirm-modal-box">
        <h5 class="fw-bold mb-1"><i class="fas fa-boxes me-2 text-warning"></i>ยืนยันการอัปเดตสต็อก</h5>
        <p class="text-muted mb-0" id="modalProductName" style="font-size:.9rem;"></p>
        <div class="confirm-qty-bar">
            <div class="text-center">
                <div class="confirm-qty-val" id="modalOldQty"></div>
                <div class="confirm-qty-lbl">เดิม</div>
            </div>
            <div class="confirm-arrow">→</div>
            <div class="text-center">
                <div class="confirm-qty-val text-primary" id="modalNewQty"></div>
                <div class="confirm-qty-lbl">ใหม่</div>
            </div>
            <div class="confirm-diff" id="modalDiff"></div>
        </div>
        <div class="d-flex gap-2 justify-content-end">
            <button onclick="closeModal()" class="btn btn-outline-secondary btn-sm px-4">ยกเลิก</button>
            <button onclick="submitForm()" class="btn btn-dark btn-sm px-4">
                <i class="fas fa-save me-1"></i>ยืนยัน
            </button>
        </div>
    </div>
</div>

<div class="stock-wrapper">
    <div class="page-header">
        <div>
            <h2 class="fw-bold mb-0"><i class="fas fa-boxes me-2"></i>จัดการสต็อกสินค้า</h2>
            <small class="text-muted">อัปเดตจำนวนสินค้าคงเหลือในคลัง</small>
        </div>
        <a asp-action="ProductList" asp-controller="Project" class="btn btn-outline-dark btn-sm">
            <i class="fas fa-arrow-left me-1"></i>กลับหน้าหลัก
        </a>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show py-2 mb-4">
            <i class="fas fa-check-circle me-1"></i> @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @{
        var totalItems  = Model.Count();
        var outOfStock  = Model.Count(s => (s.Quantity ?? 0) <= 0);
        var lowStock    = Model.Count(s => (s.Quantity ?? 0) > 0 && (s.Quantity ?? 0) <= 5);
        var normalStock = Model.Count(s => (s.Quantity ?? 0) > 5);
    }

    <div class="summary-bar">
        <div class="summary-item">
            <div class="val">@totalItems</div>
            <div class="lbl">สินค้าทั้งหมด</div>
        </div>
        <div class="summary-item">
            <div class="val text-success">@normalStock</div>
            <div class="lbl">สต็อกปกติ</div>
        </div>
        <div class="summary-item">
            <div class="val text-warning">@lowStock</div>
            <div class="lbl">เหลือน้อย (≤5)</div>
        </div>
        <div class="summary-item">
            <div class="val text-danger">@outOfStock</div>
            <div class="lbl">หมดสต็อก</div>
        </div>
    </div>

    <div class="stock-card">
        <table class="table mb-0">
            <thead>
                <tr>
                    <th>#</th>
                    <th>ชื่อสินค้า</th>
                    <th>ประเภท</th>
                    <th>ยี่ห้อ</th>
                    <th class="text-center">สถานะ</th>
                    <th class="text-center">คงเหลือ</th>
                    <th>อัปเดตล่าสุด</th>
                    <th class="text-center">แก้ไข</th>
                    <th class="text-center">ประวัติ</th>
                </tr>
            </thead>
            <tbody>
            @foreach (var s in Model)
            {
                var qty     = s.Quantity ?? 0;
                var isLow   = qty > 0 && qty <= 5;
                var isEmpty = qty <= 0;
                <tr class="@(isLow || isEmpty ? "low-row" : "")">
                    <td class="text-muted small">@s.Pid</td>
                    <td class="fw-semibold">@s.PidNavigation?.Pname</td>
                    <td class="text-muted small">@(s.PidNavigation?.Cat?.CatName ?? "-")</td>
                    <td class="text-muted small">@(s.PidNavigation?.Brand?.BrandName ?? "-")</td>
                    <td class="text-center">
                        @if (isEmpty)
                        { <span class="badge-stock bg-danger text-white">หมดสต็อก</span> }
                        else if (isLow)
                        { <span class="badge-stock bg-warning text-dark">เหลือน้อย</span> }
                        else
                        { <span class="badge-stock bg-success text-white">ปกติ</span> }
                    </td>
                    <td class="text-center fw-bold fs-5">@qty</td>
                    <td class="text-muted small">@(s.LastUpdate?.ToString("dd/MM/yyyy HH:mm") ?? "-")</td>
                    <td class="text-center">
                        <form asp-action="UpdateStock" asp-controller="Project"
                              method="post" class="d-flex gap-2 justify-content-center"
                              id="form-@s.Pid" onsubmit="return false;">
                            <input type="hidden" name="pid" value="@s.Pid" />
                            <input type="number" name="quantity" value="@qty"
                                   min="0" class="qty-input" id="input-@s.Pid" />
                            <button type="button" class="btn-save"
                                    onclick="showConfirm(@s.Pid, '@(s.PidNavigation?.Pname ?? "สินค้า")', @qty)">
                                <i class="fas fa-save me-1"></i>บันทึก
                            </button>
                        </form>
                    </td>
                    <td class="text-center">
                        <a asp-action="StockHistory" asp-controller="Project"
                           asp-route-pid="@s.Pid" class="btn-history">
                            <i class="fas fa-history me-1"></i>ประวัติ
                        </a>
                    </td>
                </tr>
            }
            </tbody>
        </table>
    </div>
</div>

@section Scripts {
<script>
    let currentForm = null;

    function showConfirm(pid, name, oldQty) {
        const newQty = parseInt(document.getElementById('input-' + pid).value);
        const diff   = newQty - oldQty;

        document.getElementById('modalProductName').textContent = name;
        document.getElementById('modalOldQty').textContent = oldQty;
        document.getElementById('modalNewQty').textContent = newQty;

        const diffEl = document.getElementById('modalDiff');
        if (diff > 0)      { diffEl.textContent = '+' + diff; diffEl.style.color = '#198754'; }
        else if (diff < 0) { diffEl.textContent = diff;       diffEl.style.color = '#dc3545'; }
        else               { diffEl.textContent = '±0';       diffEl.style.color = '#adb5bd'; }

        currentForm = document.getElementById('form-' + pid);
        document.getElementById('confirmModal').classList.add('show');
    }

    function closeModal() {
        document.getElementById('confirmModal').classList.remove('show');
        currentForm = null;
    }

    function submitForm() {
        if (currentForm) {
            currentForm.onsubmit = null;
            currentForm.submit();
        }
    }

    document.getElementById('confirmModal').addEventListener('click', function(e) {
        if (e.target === this) closeModal();
    });
</script>
}
