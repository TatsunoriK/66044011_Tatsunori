@model IEnumerable<_66044011_Tatsunori.Models.Productstock>
@{
    ViewData["Title"] = "จัดการสต็อก";
    var sorted = Model
        .OrderBy(s => s.Quantity > 5 ? 2 : s.Quantity > 0 ? 1 : 0)
        .ThenBy(s => s.PidNavigation?.Pname);
}

@section Styles {
    <link rel="stylesheet" href="~/css/stockList.css" asp-append-version="true">
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="fw-bold mb-0"><i class="fas fa-boxes me-2"></i>จัดการสต็อก</h2>
    <button class="btn btn-dark fw-bold" data-bs-toggle="modal" data-bs-target="#addProductModal">
        <i class="fas fa-plus me-1"></i>เพิ่มสินค้าใหม่
    </button>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show">
        <i class="fas fa-check-circle me-1"></i>@TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show">
        <i class="fas fa-exclamation-circle me-1"></i>@TempData["Error"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="table-responsive">
    <table class="table table-hover align-middle">
        <thead class="table-dark">
            <tr>
                <th>#</th>
                <th>สินค้า</th>
                <th>หมวด</th>
                <th>ยี่ห้อ</th>
                <th class="text-center">สถานะ</th>
                <th class="text-center">คงเหลือ</th>
                <th>อัปเดตล่าสุด</th>
                <th class="text-center">จัดการ</th>
            </tr>
        </thead>
        <tbody>
        @foreach (var s in sorted)
        {
            var qty = s.Quantity ?? 0;
            var img = s.PidNavigation?.ImagePath;
            <tr>
                <td class="text-muted small">@s.Pid</td>
                <td>
                    <div class="product-name-cell">
                        <span class="fw-semibold">@(s.PidNavigation?.Pname ?? "-")</span>
                        @if (!string.IsNullOrEmpty(img))
                        {
                            <div class="img-tooltip">
                                <img src="@img" alt="@s.PidNavigation?.Pname">
                            </div>
                        }
                    </div>
                    @if (!string.IsNullOrEmpty(s.PidNavigation?.Description))
                    {
                        <div class="text-muted small">@s.PidNavigation!.Description</div>
                    }
                </td>
                <td class="small text-muted">@(s.PidNavigation?.Cat?.CatName ?? "-")</td>
                <td class="small text-muted">@(s.PidNavigation?.Brand?.BrandName ?? "-")</td>
                <td class="text-center">
                    @if (qty <= 0)     { <span class="badge bg-danger">หมด</span> }
                    else if (qty <= 5) { <span class="badge bg-warning text-dark">เหลือน้อย</span> }
                    else               { <span class="badge bg-success">มีสินค้า</span> }
                </td>
                <td class="text-center">
                    <form asp-action="UpdateStock" method="post" class="qty-form d-inline-flex flex-column align-items-center gap-1">
                        <input type="hidden" name="pid" value="@s.Pid">
                        <input type="number" name="quantity" value="@qty" min="0"
                               class="form-control form-control-sm qty-input"
                               data-orig="@qty">
                        <button type="submit" class="btn btn-dark btn-sm save-btn" style="display:none;">
                            <i class="fas fa-check me-1"></i>บันทึก
                        </button>
                    </form>
                </td>
                <td class="small text-muted">@s.LastUpdate?.ToString("dd/MM/yy HH:mm")</td>
                <td class="text-center">
                    <div class="d-flex gap-1 justify-content-center">
                        @* ประวัติ *@
                        <a asp-action="StockHistory" asp-route-pid="@s.Pid"
                           class="btn btn-sm btn-outline-secondary" title="ประวัติ">
                            <i class="fas fa-history"></i>
                        </a>
                        @* Edit *@
                        <button type="button" class="btn btn-sm btn-outline-warning" title="แก้ไข"
                                onclick="openEdit(@s.Pid,
                                    '@Html.Raw(s.PidNavigation?.Pname?.Replace("'","\\'")??"")' ,
                                    @(s.PidNavigation?.Price ?? 0),
                                    '@Html.Raw(s.PidNavigation?.Description?.Replace("'","\\'")??"")' ,
                                    @(s.PidNavigation?.CatId?.ToString() ?? "null"),
                                    @(s.PidNavigation?.BrandId?.ToString() ?? "null"),
                                    '@(s.PidNavigation?.ImagePath ?? "")')">
                            <i class="fas fa-edit"></i>
                        </button>
                        @* Delete *@
                        <form asp-action="DeleteProduct" method="post" style="display:inline;"
                              onsubmit="return confirm('ลบสินค้า \'@(s.PidNavigation?.Pname ?? s.Pid.ToString())\' ออกจากระบบ?')">
                            <input type="hidden" name="pid" value="@s.Pid">
                            <button type="submit" class="btn btn-sm btn-outline-danger" title="ลบ">
                                <i class="fas fa-trash"></i>
                            </button>
                        </form>
                    </div>
                </td>
            </tr>
        }
        </tbody>
    </table>
</div>

@* ── Add Product Modal ── *@
<div class="modal fade" id="addProductModal" tabindex="-1">
    <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header bg-dark text-white">
                <h5 class="modal-title fw-bold">
                    <i class="fas fa-plus me-2 text-warning"></i>เพิ่มสินค้าใหม่
                </h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <form asp-action="AddProduct" method="post" enctype="multipart/form-data">
                    <div class="row g-3">
                        <div class="col-12">
                            <label class="form-label fw-semibold">ชื่อสินค้า <span class="text-danger">*</span></label>
                            <input type="text" name="pname" class="form-control" required>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-semibold">ราคา (฿) <span class="text-danger">*</span></label>
                            <input type="number" name="price" class="form-control" min="0" step="0.01" required>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-semibold">จำนวนสต็อก <span class="text-danger">*</span></label>
                            <input type="number" name="quantity" class="form-control" min="0" value="0" required>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-semibold">หมวดหมู่</label>
                            <select name="catId" class="form-select" id="catSelect" onchange="toggleNew(this,'newCatWrap')">
                                <option value="">-- ไม่ระบุ --</option>
                                @foreach (var c in (IEnumerable<_66044011_Tatsunori.Models.Category>)ViewBag.Categories)
                                {
                                    <option value="@c.CatId">@c.CatName</option>
                                }
                                <option value="__new__">➕ เพิ่มหมวดใหม่...</option>
                            </select>
                            <div id="newCatWrap" style="display:none;" class="mt-2">
                                <input type="text" name="newCatName" class="form-control" placeholder="ชื่อหมวดหมู่ใหม่">
                            </div>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-semibold">ยี่ห้อ</label>
                            <select name="brandId" class="form-select" id="brandSelect" onchange="toggleNew(this,'newBrandWrap')">
                                <option value="">-- ไม่ระบุ --</option>
                                @foreach (var b in (IEnumerable<_66044011_Tatsunori.Models.Brand>)ViewBag.Brands)
                                {
                                    <option value="@b.BrandId">@b.BrandName</option>
                                }
                                <option value="__new__">➕ เพิ่มยี่ห้อใหม่...</option>
                            </select>
                            <div id="newBrandWrap" style="display:none;" class="mt-2">
                                <input type="text" name="newBrandName" class="form-control" placeholder="ชื่อยี่ห้อใหม่">
                            </div>
                        </div>
                        <div class="col-12">
                            <label class="form-label fw-semibold">รูปสินค้า</label>
                            <input type="file" name="image" class="form-control" accept="image/*" onchange="previewImg(this,'imgPreview','imgPreviewWrap')">
                            <div class="mt-2 text-center" id="imgPreviewWrap" style="display:none;">
                                <img id="imgPreview" src="" class="rounded border edit-img-preview">
                            </div>
                        </div>
                        <div class="col-12">
                            <label class="form-label fw-semibold">รายละเอียด</label>
                            <textarea name="description" class="form-control" rows="2"></textarea>
                        </div>
                    </div>
                    <div class="d-flex justify-content-end gap-2 mt-3">
                        <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">ยกเลิก</button>
                        <button type="submit" class="btn btn-dark fw-bold">เพิ่มสินค้า</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@* ── Edit Product Modal ── *@
<div class="modal fade" id="editProductModal" tabindex="-1">
    <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header bg-dark text-white">
                <h5 class="modal-title fw-bold">
                    <i class="fas fa-edit me-2 text-warning"></i>แก้ไขสินค้า
                </h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <form asp-action="EditProduct" method="post" enctype="multipart/form-data" id="editProductForm">
                    <input type="hidden" name="pid" id="editPid">
                    <div class="row g-3">
                        <div class="col-12">
                            <label class="form-label fw-semibold">ชื่อสินค้า <span class="text-danger">*</span></label>
                            <input type="text" name="pname" id="editPname" class="form-control" required>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-semibold">ราคา (฿) <span class="text-danger">*</span></label>
                            <input type="number" name="price" id="editPrice" class="form-control" min="0" step="0.01" required>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-semibold">หมวดหมู่</label>
                            <select name="catId" id="editCatId" class="form-select">
                                <option value="">-- ไม่ระบุ --</option>
                                @foreach (var c in (IEnumerable<_66044011_Tatsunori.Models.Category>)ViewBag.Categories)
                                {
                                    <option value="@c.CatId">@c.CatName</option>
                                }
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-semibold">ยี่ห้อ</label>
                            <select name="brandId" id="editBrandId" class="form-select">
                                <option value="">-- ไม่ระบุ --</option>
                                @foreach (var b in (IEnumerable<_66044011_Tatsunori.Models.Brand>)ViewBag.Brands)
                                {
                                    <option value="@b.BrandId">@b.BrandName</option>
                                }
                            </select>
                        </div>
                        <div class="col-12">
                            <label class="form-label fw-semibold">รูปสินค้า</label>
                            <div id="editCurrentImg" class="mb-2" style="display:none;">
                                <img id="editCurrentImgEl" src="" class="rounded border edit-img-preview">
                                <div class="small text-muted mt-1">รูปปัจจุบัน — อัปโหลดรูปใหม่เพื่อเปลี่ยน</div>
                            </div>
                            <input type="file" name="image" class="form-control" accept="image/*"
                                   onchange="previewImg(this,'editNewPreview','editNewPreviewWrap')">
                            <div class="mt-2 text-center" id="editNewPreviewWrap" style="display:none;">
                                <img id="editNewPreview" src="" class="rounded border edit-img-preview">
                            </div>
                        </div>
                        <div class="col-12">
                            <label class="form-label fw-semibold">รายละเอียด</label>
                            <textarea name="description" id="editDescription" class="form-control" rows="2"></textarea>
                        </div>
                    </div>
                    <div class="d-flex justify-content-end gap-2 mt-3">
                        <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">ยกเลิก</button>
                        <button type="submit" class="btn btn-warning fw-bold text-dark">
                            <i class="fas fa-save me-1"></i>บันทึกการแก้ไข
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
// Tooltip follow mouse
document.querySelectorAll('.product-name-cell').forEach(function(cell) {
    var tooltip = cell.querySelector('.img-tooltip');
    if (!tooltip) return;
    cell.addEventListener('mousemove', function(e) {
        tooltip.style.left = (e.clientX + 12) + 'px';
        tooltip.style.top  = (e.clientY - 60) + 'px';
    });
});

// แสดงปุ่มบันทึกเมื่อค่าเปลี่ยน
document.querySelectorAll('.qty-form').forEach(function(form) {
    var input = form.querySelector('.qty-input');
    var btn   = form.querySelector('.save-btn');
    var orig  = parseInt(input.dataset.orig);
    input.addEventListener('input', function() {
        var v = parseInt(input.value);
        if (isNaN(v) || v < 0) input.value = 0;
        btn.style.display = parseInt(input.value) !== orig ? 'inline-block' : 'none';
    });
});

// toggle input ใหม่
function toggleNew(sel, wrapId) {
    var wrap  = document.getElementById(wrapId);
    var input = wrap.querySelector('input');
    if (sel.value === '__new__') {
        wrap.style.display = 'block'; input.required = true; sel.value = '';
    } else {
        wrap.style.display = 'none'; input.required = false; input.value = '';
    }
}

// preview รูป
function previewImg(input, imgId, wrapId) {
    var wrap = document.getElementById(wrapId);
    var img  = document.getElementById(imgId);
    if (input.files && input.files[0]) {
        var reader = new FileReader();
        reader.onload = function(e) { img.src = e.target.result; wrap.style.display = 'block'; };
        reader.readAsDataURL(input.files[0]);
    } else {
        wrap.style.display = 'none';
    }
}

// เปิด Edit Modal พร้อมข้อมูล
function openEdit(pid, pname, price, description, catId, brandId, imagePath) {
    document.getElementById('editPid').value         = pid;
    document.getElementById('editPname').value       = pname;
    document.getElementById('editPrice').value       = price;
    document.getElementById('editDescription').value = description;
    document.getElementById('editCatId').value       = catId || '';
    document.getElementById('editBrandId').value     = brandId || '';

    // reset new image preview
    document.getElementById('editNewPreviewWrap').style.display = 'none';
    document.getElementById('editProductForm').querySelector('input[type=file]').value = '';

    // แสดงรูปปัจจุบัน
    var curImgWrap = document.getElementById('editCurrentImg');
    var curImgEl   = document.getElementById('editCurrentImgEl');
    if (imagePath) {
        curImgEl.src = imagePath;
        curImgWrap.style.display = 'block';
    } else {
        curImgWrap.style.display = 'none';
    }

    var modal = new bootstrap.Modal(document.getElementById('editProductModal'));
    modal.show();
}
</script>
}
