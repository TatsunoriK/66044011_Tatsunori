@model IEnumerable<_66044011_Tatsunori.ViewModels.CartItemViewModel>
@{
    Layout = "_HeaderFoot";
    ViewData["Title"] = "ตะกร้าสินค้า";
    var total = Model.Sum(i => i.Subtotal);
}

@section Styles {
<style>
    .cart-wrapper { max-width: 960px; margin: 0 auto; }
    .cart-table { background: #fff; border-radius: 12px; border: 1px solid #eee; overflow: hidden; }
    .cart-table th { background: #1a1a1a; color: #fff; padding: 14px 20px; font-weight: 600; font-size: .85rem; }
    .cart-table td { padding: 14px 20px; vertical-align: middle; border-bottom: 1px solid #f5f5f5; }
    .qty-input { width: 70px; text-align: center; border: 1px solid #ddd; border-radius: 6px; padding: 6px; }
    .btn-remove { background: none; border: none; color: #dc3545; font-size: 1.2rem; cursor: pointer; transition: .2s; }
    .btn-remove:hover { color: #a71d2a; transform: scale(1.2); }
    .order-summary { background: #fff; border-radius: 12px; border: 1px solid #eee; padding: 24px; }
    .btn-checkout { background: #1a1a1a; color: #fff; border: none; padding: 14px; border-radius: 10px;
                    font-weight: 700; font-size: 1rem; width: 100%; transition: .2s; cursor: pointer; }
    .btn-checkout:hover { background: #f39c12; color: #1a1a1a; }
    .empty-cart { text-align: center; padding: 80px 20px; color: #adb5bd; }
</style>
}

<div class="cart-wrapper py-2">
    <h2 class="fw-bold mb-4"><i class="fas fa-shopping-cart me-2"></i>ตะกร้าสินค้า</h2>

    @if (TempData["OrderSuccess"] != null)
    {
        <div class="alert alert-success">
            <i class="fas fa-check-circle me-1"></i> @TempData["OrderSuccess"]
        </div>
    }

    @if (!Model.Any())
    {
        <div class="empty-cart">
            <i class="fas fa-cart-arrow-down fa-3x mb-3"></i>
            <h5>ตะกร้าของคุณว่างเปล่า</h5>
            <a asp-action="ProductList" class="btn btn-dark mt-3">
                <i class="fas fa-store me-1"></i>เลือกซื้อสินค้า
            </a>
        </div>
    }
    else
    {
        <div class="row g-4">
            <div class="col-lg-8">
                <div class="cart-table">
                    <table class="table mb-0">
                        <thead>
                            <tr>
                                <th>สินค้า</th>
                                <th class="text-center">ราคา/ชิ้น</th>
                                <th class="text-center">จำนวน</th>
                                <th class="text-end">รวม</th>
                                <th class="text-center">ลบ</th>
                            </tr>
                        </thead>
                        <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td class="fw-semibold">@item.Pname</td>
                                <td class="text-center">฿@item.Price.ToString("N0")</td>
                                <td class="text-center">
                                    <form asp-action="UpdateCart" method="post" class="d-inline">
                                        <input type="hidden" name="pid" value="@item.Pid" />
                                        <input type="number" name="qty" value="@item.Qty" min="1"
                                               class="qty-input" onchange="this.form.submit()" />
                                    </form>
                                </td>
                                <td class="text-end fw-bold text-primary">฿@item.Subtotal.ToString("N0")</td>
                                <td class="text-center">
                                    <form asp-action="RemoveFromCart" method="post" class="d-inline">
                                        <input type="hidden" name="pid" value="@item.Pid" />
                                        <button type="submit" class="btn-remove" title="ลบ">
                                            <i class="fas fa-times-circle"></i>
                                        </button>
                                    </form>
                                </td>
                            </tr>
                        }
                        </tbody>
                    </table>
                </div>
                <div class="mt-3">
                    <a asp-action="ProductList" class="btn btn-outline-dark btn-sm">
                        <i class="fas fa-arrow-left me-1"></i>เลือกสินค้าต่อ
                    </a>
                </div>
            </div>

            <div class="col-lg-4">
                <div class="order-summary">
                    <h5 class="fw-bold mb-3">สรุปรายการ</h5>
                    <hr />
                    <div class="d-flex justify-content-between mb-2">
                        <span class="text-muted">จำนวนสินค้า</span>
                        <span>@Model.Sum(i => i.Qty) ชิ้น</span>
                    </div>
                    <div class="d-flex justify-content-between mb-3">
                        <span class="text-muted">ยอดรวม</span>
                        <span class="fw-bold fs-5 text-primary">฿@total.ToString("N0")</span>
                    </div>
                    <hr />
                    <form asp-action="PlaceOrder" method="post">
                        <button type="submit" class="btn-checkout"
                                onclick="return confirm('ยืนยันการสั่งซื้อ?')">
                            <i class="fas fa-credit-card me-2"></i>สั่งซื้อเลย
                        </button>
                    </form>
                </div>
            </div>
        </div>
    }
</div>
