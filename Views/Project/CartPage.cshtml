@model IEnumerable<_66044011_Tatsunori.ViewModels.CartItemViewModel>
@{
    Layout = "_HeaderFoot";
    ViewData["Title"] = "ตะกร้าสินค้า";
    var total = Model.Sum(i => i.Subtotal);
}

@section Styles {
    <link rel="stylesheet" href="~/css/cart.css" asp-append-version="true">
}

<div class="cart-wrapper">
    <h2 class="fw-bold mb-4"><i class="fas fa-shopping-cart me-2"></i>ตะกร้าสินค้า</h2>

    @if (!Model.Any())
    {
        <div class="empty-cart">
            <i class="fas fa-cart-arrow-down fa-3x mb-3"></i>
            <h5>ตะกร้าของคุณว่างเปล่า</h5>
            <a asp-action="ProductList" asp-controller="Project" class="btn btn-dark mt-3">
                <i class="fas fa-store me-1"></i>เลือกซื้อสินค้า
            </a>
        </div>
    }
    else
    {
        <div class="row g-4">
            <div class="col-lg-8">
                <div class="cart-card">
                    <table class="table mb-0">
                        <thead>
                            <tr>
                                <th>สินค้า</th>
                                <th class="text-center">ราคา/ชิ้น</th>
                                <th class="text-center">จำนวน</th>
                                <th class="text-end">รวม</th>
                                <th class="text-center">ลบ</th>
                            </tr>
                        </thead>
                        <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td class="fw-semibold">@item.Pname</td>
                                <td class="text-center">฿@item.Price.ToString("N0")</td>
                                <td class="text-center">
                                    <form asp-action="UpdateCart" asp-controller="Project"
                                          method="post" class="d-inline">
                                        <input type="hidden" name="pid" value="@item.Pid" />
                                        <input type="number" name="qty" value="@item.Qty"
                                               min="1" class="qty-input"
                                               onchange="this.form.submit()" />
                                    </form>
                                </td>
                                <td class="text-end fw-bold text-primary">
                                    ฿@item.Subtotal.ToString("N0")
                                </td>
                                <td class="text-center">
                                    <form asp-action="RemoveFromCart" asp-controller="Project"
                                          method="post" class="d-inline">
                                        <input type="hidden" name="pid" value="@item.Pid" />
                                        <button type="submit" class="btn-remove">
                                            <i class="fas fa-times-circle"></i>
                                        </button>
                                    </form>
                                </td>
                            </tr>
                        }
                        </tbody>
                    </table>
                </div>
                <div class="mt-3">
                    <a asp-action="ProductList" asp-controller="Project"
                       class="btn btn-outline-dark btn-sm">
                        <i class="fas fa-arrow-left me-1"></i>เลือกสินค้าต่อ
                    </a>
                </div>
            </div>

            <div class="col-lg-4">
                <div class="summary-card">
                    <h5 class="fw-bold mb-3">สรุปรายการ</h5>
                    <hr />
                    <div class="d-flex justify-content-between mb-2 text-muted">
                        <span>จำนวนสินค้า</span>
                        <span>@Model.Sum(i => i.Qty) ชิ้น</span>
                    </div>
                    <div class="d-flex justify-content-between mb-3">
                        <span class="fw-semibold">ยอดรวม</span>
                        <span class="fw-bold fs-5 text-primary">฿@total.ToString("N0")</span>
                    </div>
                    <hr />
                    <form asp-action="PlaceOrder" asp-controller="Project" method="post">
                        <button type="submit" class="btn-checkout"
                                onclick="return confirm('ยืนยันการสั่งซื้อ?')">
                            <i class="fas fa-credit-card me-2"></i>สั่งซื้อเลย
                        </button>
                    </form>
                </div>
            </div>
        </div>
    }
</div>