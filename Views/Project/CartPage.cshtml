@model IEnumerable<_66044011_Tatsunori.ViewModels.CartItemViewModel>
@{
    ViewData["Title"] = "ตะกร้าสินค้า";
    var subtotal     = Model.Sum(i => i.Subtotal);
    int userPoints   = (int)(ViewBag.UserPoints ?? 0);

    bool isMember       = (Context.Session.GetString("IsMember") == "1");
    string memberExpStr = Context.Session.GetString("MemberExpiry") ?? "";
    DateTime? memberExp = string.IsNullOrEmpty(memberExpStr) ? null : DateTime.Parse(memberExpStr);
    bool memberActive   = isMember && memberExp != null && memberExp >= DateTime.Now;
    // เช็ค quota จาก controller (ใช้แล้วเดือนนี้หรือยัง)
    bool memberDiscAvail = (bool)(ViewBag.MemberDiscAvailable ?? false);
    decimal memDisc     = (memberActive && memberDiscAvail) ? 100m : 0m;

    var availableCoupons  = ViewBag.AvailableCoupons as List<_66044011_Tatsunori.Models.Coupon>
                            ?? new List<_66044011_Tatsunori.Models.Coupon>();
    string? memberCouponCode = ViewBag.MemberCouponCode as string;
}

@section Styles {
    <link rel="stylesheet" href="~/css/cart.css" asp-append-version="true">
    <style>
        /* Confirm Modal */
        .cart-modal-overlay { display:none; position:fixed; inset:0; background:rgba(0,0,0,.55); z-index:9999; align-items:center; justify-content:center; }
        .cart-modal-overlay.show { display:flex; }
        .cart-confirm-modal { background:#fff; border-radius:20px; padding:28px; max-width:440px; width:94%; box-shadow:0 20px 60px rgba(0,0,0,.2); max-height:90vh; overflow-y:auto; }
        .cart-confirm-modal h5 { font-weight:800; font-size:1.1rem; margin-bottom:16px; }

        .order-sum-table { width:100%; border-collapse:collapse; margin-bottom:14px; }
        .order-sum-table td { padding:7px 0; border-bottom:1px solid #f3f4f6; font-size:.88rem; vertical-align:middle; }
        .order-sum-table tr:last-child td { border:none; }
        .order-sum-table .item-name { color:#374151; }
        .order-sum-table .item-price { text-align:right; font-weight:600; white-space:nowrap; }
        .sum-divider td { border-top:2px solid #e5e7eb !important; padding-top:10px !important; }
        .sum-discount td { color:#059669; }
        .sum-total td { font-weight:800; font-size:1rem; }
        .sum-earn td  { color:#f39c12; font-size:.82rem; }

        .pay-title { font-size:.78rem; font-weight:700; color:#9ca3af; text-transform:uppercase; letter-spacing:.06em; margin-bottom:10px; }
        .pay-grid  { display:grid; grid-template-columns:1fr 1fr; gap:8px; margin-bottom:14px; }
        .pay-option { border:2px solid #e5e7eb; border-radius:10px; padding:10px; text-align:center; cursor:pointer; transition:.15s; font-size:.85rem; font-weight:600; background:#fff; }
        .pay-option:hover, .pay-option.picked { border-color:#111; background:#111; color:#fff; }
        .pay-option i { display:block; font-size:1.3rem; margin-bottom:4px; }

        .pay-ok-msg { background:#d1fae5; color:#065f46; border-radius:8px; padding:9px 12px; font-size:.83rem; margin-bottom:12px; display:none; }
        .pay-ok-msg.show { display:block; }

        .btn-confirm-order { width:100%; padding:13px; background:#111; color:#fff; border:none; border-radius:10px; font-weight:800; font-size:.95rem; cursor:pointer; transition:.2s; }
        .btn-confirm-order:disabled { opacity:.35; cursor:not-allowed; }
        .btn-confirm-order:not(:disabled):hover { background:#f39c12; color:#111; }
        .btn-modal-cancel { width:100%; padding:9px; background:transparent; border:none; color:#9ca3af; font-size:.85rem; cursor:pointer; margin-top:6px; }
    </style>
}

<h2 class="fw-bold mb-4"><i class="fas fa-shopping-cart me-2"></i>ตะกร้าสินค้า</h2>

@if (TempData["CartError"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show">
        <i class="fas fa-exclamation-triangle me-1"></i> @TempData["CartError"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

@if (!Model.Any())
{
    <div class="text-center py-5 text-muted">
        <i class="fas fa-cart-arrow-down fa-3x mb-3"></i>
        <h5>ตะกร้าว่างเปล่า</h5>
        <a asp-action="ProductList" class="btn btn-dark mt-3">เลือกซื้อสินค้า</a>
    </div>
}
else
{
    <div class="row g-4">
        <div class="col-lg-8">
            <div class="cart-table">
                @foreach (var item in Model)
                {
                    <div class="cart-row">
                        <div class="cart-icon"><i class="fas fa-gun fa-2x opacity-25"></i></div>
                        <div class="cart-info flex-grow-1">
                            <div class="fw-bold">@item.Pname</div>
                            <div class="text-primary fw-semibold">฿@item.Price.ToString("N0") / ชิ้น</div>
                        </div>
                        <form asp-action="UpdateCart" method="post" class="d-flex align-items-center gap-2">
                            <input type="hidden" name="pid" value="@item.Pid" />
                            <input type="number" name="qty" value="@item.Qty" min="1"
                                   class="form-control form-control-sm qty-input"
                                   onchange="this.form.submit()">
                        </form>
                        <div class="fw-bold text-primary mx-3">฿@item.Subtotal.ToString("N0")</div>
                        <form asp-action="RemoveFromCart" method="post">
                            <input type="hidden" name="pid" value="@item.Pid" />
                            <button type="submit" class="btn btn-sm btn-outline-danger">
                                <i class="fas fa-trash"></i>
                            </button>
                        </form>
                    </div>
                }
            </div>
        </div>

        <div class="col-lg-4">
            <div class="summary-card">
                <h5 class="fw-bold mb-3">สรุปคำสั่งซื้อ</h5>

                @* Member badge *@
                @if (memberActive)
                {
                    <div class="member-badge member-gold mb-3">
                        <i class="fas fa-crown me-1"></i> Member
                        <span class="ms-1 small">(ส่วนลด ฿100/เดือน)</span>
                    </div>
                }

                @* ยอดรวม *@
                <div class="d-flex justify-content-between mb-1">
                    <span class="text-muted">ยอดรวม</span>
                    <span class="fw-semibold">฿@subtotal.ToString("N0")</span>
                </div>
                @if (memDisc > 0)
                {
                    <div class="d-flex justify-content-between mb-2 text-success small">
                        <span><i class="fas fa-crown me-1"></i>ส่วนลด Member</span>
                        <span>-฿@memDisc.ToString("N0")</span>
                    </div>
                }

                <hr class="my-2">

                @* Coupon *@
                <div class="mb-3">
                    <label class="form-label small fw-semibold">
                        <i class="fas fa-ticket-alt me-1 text-warning"></i>เลือก Coupon
                    </label>
                    @if (!availableCoupons.Any())
                    {
                        <div class="text-muted small py-1">
                            <i class="fas fa-info-circle me-1"></i>ไม่มี Coupon ที่ใช้ได้ขณะนี้
                        </div>
                    }
                    else
                    {
                        <select class="form-select form-select-sm" id="couponSelect"
                                onchange="recalc()">
                            <option value="" data-pct="0" data-amt="0" data-min="0">-- ไม่ใช้ Coupon --</option>
                            @foreach (var c in availableCoupons)
                            {
                                <option value="@c.Code"
                                        data-pct="@c.DiscountPct"
                                        data-amt="@c.DiscountAmt"
                                        data-min="@c.MinAmount"
                                        data-limit="@c.UsageLimit">
                                    @c.Code —
                                    @(c.DiscountAmt > 0 ? $"ลด ฿{c.DiscountAmt:N0}" : $"ลด {c.DiscountPct}%")
                                    @(c.MinAmount > 0 ? $" (ขั้นต่ำ ฿{c.MinAmount:N0})" : "")
                                    @(c.UsageLimit > 1 ? $" [{c.UsageLimit}ครั้ง/คน]" : "")
                                </option>
                            }
                        </select>
                        <div id="couponMsg" class="small mt-1" style="display:none;"></div>
                    }
                </div>

                @* Points *@
                <div class="mb-3">
                    <label class="form-label small fw-semibold">
                        <i class="fas fa-coins me-1 text-warning"></i>ใช้แต้ม
                    </label>
                    <div class="points-info-box mb-2">
                        <span class="points-current">@userPoints <small>แต้ม</small></span>
                        <span class="points-eq">= ส่วนลด ฿@(userPoints / 10)</span>
                    </div>
                    @if (userPoints > 0)
                    {
                        <div class="input-group input-group-sm">
                            <span class="input-group-text bg-light"><i class="fas fa-coins text-warning"></i></span>
                            <input type="number" id="pointsInput" class="form-control"
                                   placeholder="0" min="0" max="@userPoints" value="0"
                                   oninput="recalc()">
                            <span class="input-group-text bg-light text-muted small" id="pointDiscDisplay">= ฿0</span>
                        </div>
                        <div class="text-muted" style="font-size:.72rem;margin-top:3px;">10 แต้ม = ฿1 | มี @userPoints แต้ม</div>
                    }
                    else
                    {
                        <div class="text-muted small">ยังไม่มีแต้มสะสม</div>
                    }
                </div>

                @* ที่อยู่ *@
                <div class="mb-3">
                    <label class="form-label small fw-semibold">
                        ที่อยู่จัดส่ง <span class="text-danger">*</span>
                    </label>
                    <textarea id="shippingAddrInput" class="form-control form-control-sm" rows="2"
                              placeholder="ระบุที่อยู่..." required>@ViewBag.SavedAddress</textarea>
                </div>

                @* สรุปยอด live *@
                <div id="liveSummary" class="mb-3" style="background:#f8f9fa;border-radius:10px;padding:10px 14px;font-size:.85rem;">
                    <div class="d-flex justify-content-between"><span class="text-muted">ยอดสินค้า</span><span>฿@subtotal.ToString("N0")</span></div>

                    <div id="liveCouponRow" class="d-flex justify-content-between text-success" style="display:none;">
                        <span id="liveCouponLabel">Coupon</span><span id="liveCouponAmt"></span>
                    </div>
                    <div id="livePointRow" class="d-flex justify-content-between text-success" style="display:none;">
                        <span>แต้มสะสม</span><span id="livePointAmt"></span>
                    </div>
                    <hr class="my-1">
                    <div class="d-flex justify-content-between fw-bold">
                        <span>ยอดสุทธิ</span><span id="liveTotal" class="text-primary">฿@subtotal.ToString("N0")</span>
                    </div>
                    <div class="text-warning small mt-1" id="earnPointsRow">
                        <i class="fas fa-coins me-1"></i>จะได้รับ <strong id="earnAmt">@((int)(subtotal/10))</strong> แต้ม
                    </div>
                </div>

                <button type="button" class="btn btn-dark w-100 fw-bold" onclick="openCartConfirm()">
                    <i class="fas fa-receipt me-1"></i>ดูสรุปและยืนยัน
                </button>
            </div>
        </div>
    </div>
}

@* ── Confirm + Pay Modal ── *@
<div class="cart-modal-overlay" id="cartModal">
    <div class="cart-confirm-modal">
        <h5><i class="fas fa-receipt me-2 text-warning"></i>ยืนยันการสั่งซื้อ</h5>

        @* รายการสินค้า *@
        <div style="background:#f8f9fa;border-radius:10px;padding:14px 16px;margin-bottom:14px;">
            <table class="order-sum-table">
                @foreach (var item in Model)
                {
                    <tr>
                        <td class="item-name">@item.Pname <span class="text-muted small">x@item.Qty</span></td>
                        <td class="item-price">฿@item.Subtotal.ToString("N0")</td>
                    </tr>
                }
                <tr class="sum-divider">
                    <td class="text-muted">ยอดรวมสินค้า</td>
                    <td class="item-price">฿@subtotal.ToString("N0")</td>
                </tr>
                @if (memDisc > 0)
                {
                    <tr class="sum-discount">
                        <td><i class="fas fa-crown me-1"></i>ส่วนลด Member</td>
                        <td class="item-price">-฿@memDisc.ToString("N0")</td>
                    </tr>
                }
                <tr class="sum-discount" id="modalCouponRow" style="display:none;">
                    <td><i class="fas fa-tag me-1"></i><span id="modalCouponLabel">Coupon</span></td>
                    <td class="item-price" id="modalCouponAmt"></td>
                </tr>
                <tr class="sum-discount" id="modalPointRow" style="display:none;">
                    <td><i class="fas fa-coins me-1"></i>แต้มสะสม</td>
                    <td class="item-price" id="modalPointAmt"></td>
                </tr>
                <tr class="sum-total">
                    <td>ยอดสุทธิ</td>
                    <td class="item-price text-primary" id="modalTotal">฿@subtotal.ToString("N0")</td>
                </tr>
                <tr class="sum-earn">
                    <td colspan="2"><i class="fas fa-coins me-1"></i>จะได้รับ <strong id="modalEarn">@((int)(subtotal/10))</strong> แต้มจากออเดอร์นี้</td>
                </tr>
            </table>
        </div>

        @* Address *@
        <div style="background:#f8f9fa;border-radius:10px;padding:10px 14px;margin-bottom:14px;font-size:.85rem;">
            <div class="text-muted small mb-1"><i class="fas fa-map-marker-alt me-1 text-warning"></i>ที่อยู่จัดส่ง</div>
            <div id="modalAddress" class="fw-semibold small"></div>
        </div>

        @* Payment *@
        <div class="pay-title"><i class="fas fa-credit-card me-1"></i>เลือกวิธีชำระเงิน</div>
        <div class="pay-grid">
            <button type="button" class="pay-option" onclick="pickPay(this)">
                <i class="fab fa-cc-visa"></i>Visa
            </button>
            <button type="button" class="pay-option" onclick="pickPay(this)">
                <i class="fab fa-cc-mastercard"></i>Mastercard
            </button>
            <button type="button" class="pay-option" onclick="pickPay(this)">
                <i class="fas fa-university"></i>โอนเงิน
            </button>
            <button type="button" class="pay-option" onclick="pickPay(this)">
                <i class="fas fa-qrcode"></i>QR Code
            </button>
        </div>

        <div class="pay-ok-msg" id="payOkMsg">
            <i class="fas fa-check-circle me-1"></i>เลือกวิธีชำระเงินแล้ว — กดยืนยันเพื่อสั่งซื้อ
        </div>

        <form asp-action="PlaceOrder" asp-controller="Project" method="post" id="placeOrderForm">
            <input type="hidden" name="couponCode"      id="hiddenCoupon">
            <input type="hidden" name="pointsToRedeem"  id="hiddenPoints" value="0">
            <input type="hidden" name="shippingAddress" id="hiddenAddress">
            <button type="submit" class="btn-confirm-order" id="confirmOrderBtn" disabled>
                <i class="fas fa-check-circle me-1"></i>ยืนยันสั่งซื้อ
            </button>
        </form>
        <button type="button" class="btn-modal-cancel" onclick="closeCartModal()">ยกเลิก / แก้ไข</button>
    </div>
</div>

@section Scripts {
<script>
var SUBTOTAL   = @subtotal;
var MAX_POINTS = @userPoints;
var MEM_DISC   = 0; // หักตอน Paid ไม่ใช่ตอน checkout // 0 ถ้าใช้ quota ไปแล้ว

function getCouponDisc() {
    var sel = document.getElementById('couponSelect');
    if (!sel || !sel.value) return 0;
    var opt = sel.options[sel.selectedIndex];
    var amt = parseFloat(opt.dataset.amt) || 0;
    var pct = parseFloat(opt.dataset.pct) || 0;
    var min = parseFloat(opt.dataset.min) || 0;
    if (SUBTOTAL < min) return 0;
    return amt > 0 ? amt : Math.round(SUBTOTAL * pct / 100);
}

function getPointDisc() {
    var inp = document.getElementById('pointsInput');
    if (!inp) return 0;
    var v = Math.min(parseInt(inp.value) || 0, MAX_POINTS);
    if (v < 0) v = 0;
    return Math.floor(v / 10);
}

function recalc() {
    var pts  = document.getElementById('pointsInput');
    if (pts) {
        var v = parseInt(pts.value) || 0;
        if (v > MAX_POINTS) { pts.value = MAX_POINTS; v = MAX_POINTS; }
        if (v < 0)          { pts.value = 0;          v = 0; }
        document.getElementById('pointDiscDisplay').textContent = '= ฿' + Math.floor(v / 10);
    }

    var couponDisc = getCouponDisc();
    var pointDisc  = getPointDisc();
    var total      = Math.max(0, SUBTOTAL - MEM_DISC - couponDisc - pointDisc);
    var earn       = Math.floor(total / 10);

    // live summary
    var sel = document.getElementById('couponSelect');
    var couponRow = document.getElementById('liveCouponRow');
    var couponMsg = document.getElementById('couponMsg');
    if (sel && sel.value) {
        var opt = sel.options[sel.selectedIndex];
        var min = parseFloat(opt.dataset.min) || 0;
        if (SUBTOTAL < min) {
            couponRow.style.display = 'none';
            couponMsg.style.display = 'block';
            couponMsg.className = 'small mt-1 text-danger';
            couponMsg.textContent = '⚠️ ยอดไม่ถึงขั้นต่ำ ฿' + min.toLocaleString();
        } else {
            couponRow.style.removeProperty('display');
            document.getElementById('liveCouponLabel').textContent = sel.value;
            document.getElementById('liveCouponAmt').textContent = '-฿' + couponDisc.toLocaleString();
            couponMsg.style.display = 'none';
        }
    } else {
        couponRow.style.display = 'none';
        if (couponMsg) couponMsg.style.display = 'none';
    }

    var pointRow = document.getElementById('livePointRow');
    if (pointDisc > 0) {
        pointRow.style.removeProperty('display');
        document.getElementById('livePointAmt').textContent = '-฿' + pointDisc.toLocaleString();
    } else {
        pointRow.style.display = 'none';
    }

    document.getElementById('liveTotal').textContent = '฿' + total.toLocaleString();
    document.getElementById('earnAmt').textContent   = earn;
}

function openCartConfirm() {
    var addr = document.getElementById('shippingAddrInput').value.trim();
    if (!addr) { alert('กรุณากรอกที่อยู่จัดส่งก่อน'); return; }

    var sel        = document.getElementById('couponSelect');
    var couponCode = sel ? sel.value : '';
    var couponDisc = getCouponDisc();
    var pointsInp  = document.getElementById('pointsInput');
    var pointsVal  = pointsInp ? parseInt(pointsInp.value) || 0 : 0;
    var pointDisc  = getPointDisc();
    var total      = Math.max(0, SUBTOTAL - MEM_DISC - couponDisc - pointDisc);
    var earn       = Math.floor(total / 10);

    // ส่งค่าไป hidden inputs
    document.getElementById('hiddenCoupon').value  = couponCode;
    document.getElementById('hiddenPoints').value  = pointsVal;
    document.getElementById('hiddenAddress').value = addr;

    // update modal
    document.getElementById('modalAddress').textContent = addr;
    document.getElementById('modalTotal').textContent   = '฿' + total.toLocaleString();
    document.getElementById('modalEarn').textContent    = earn;

    var mCoupon = document.getElementById('modalCouponRow');
    if (couponCode && couponDisc > 0) {
        mCoupon.style.removeProperty('display');
        document.getElementById('modalCouponLabel').textContent = couponCode;
        document.getElementById('modalCouponAmt').textContent   = '-฿' + couponDisc.toLocaleString();
    } else { mCoupon.style.display = 'none'; }

    var mPoint = document.getElementById('modalPointRow');
    if (pointDisc > 0) {
        mPoint.style.removeProperty('display');
        document.getElementById('modalPointAmt').textContent = '-฿' + pointDisc.toLocaleString();
    } else { mPoint.style.display = 'none'; }

    // reset payment
    document.querySelectorAll('.pay-option').forEach(b => b.classList.remove('picked'));
    document.getElementById('payOkMsg').classList.remove('show');
    document.getElementById('confirmOrderBtn').disabled = true;
    document.getElementById('cartModal').classList.add('show');
}

function closeCartModal() {
    document.getElementById('cartModal').classList.remove('show');
}

function pickPay(btn) {
    document.querySelectorAll('.pay-option').forEach(b => b.classList.remove('picked'));
    btn.classList.add('picked');
    document.getElementById('payOkMsg').classList.add('show');
    document.getElementById('confirmOrderBtn').disabled = false;
}

document.getElementById('cartModal').addEventListener('click', function(e) {
    if (e.target === this) closeCartModal();
});

// init
recalc();
</script>
}
