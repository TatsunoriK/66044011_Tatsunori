@model _66044011_Tatsunori.Models.User
@{
    ViewData["Title"] = "โปรไฟล์";
    bool isMember   = Model.IsMember && Model.MemberExpiry != null && Model.MemberExpiry >= DateTime.Now;
    int  daysLeft   = isMember ? (int)(Model.MemberExpiry!.Value - DateTime.Now).TotalDays + 1 : 0;
}

@section Styles {
    <link rel="stylesheet" href="~/css/myProfile.css" asp-append-version="true">
}

<div class="profile-wrapper">

    @if (TempData["ProfileSuccess"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show mb-4 py-2">
            <i class="fas fa-check-circle me-1"></i> @TempData["ProfileSuccess"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @* ── Header ── *@
    <div class="d-flex align-items-center gap-3 mb-4">
        <img src="https://ui-avatars.com/api/?name=@Uri.EscapeDataString(Model.FullName ?? Model.Username)&background=0d1b2a&color=f4c430&size=72"
             class="profile-avatar" alt="avatar">
        <div>
            <h4 class="fw-bold mb-0">@(Model.FullName ?? Model.Username)</h4>
            <div class="text-muted small">@Model.Email</div>
            <div class="mt-1">
                @if (isMember)
                {
                    <span class="badge" style="background:#f4c430;color:#111;font-size:.75rem;">
                        <i class="fas fa-crown me-1"></i>Member — เหลือ @daysLeft วัน
                    </span>
                }
                else
                {
                    <span class="badge bg-secondary" style="font-size:.75rem;">Bronze (ฟรี)</span>
                }
            </div>
        </div>
    </div>

    @* ── ข้อมูลส่วนตัว (View Mode) ── *@
    <div class="profile-card" id="viewSection">
        <div class="d-flex justify-content-between align-items-center mb-3">
            <h6 class="fw-bold mb-0"><i class="fas fa-user me-2 text-warning"></i>ข้อมูลส่วนตัว</h6>
            <button type="button" class="btn btn-sm btn-outline-warning fw-semibold"
                    onclick="toggleEdit(true)">
                <i class="fas fa-edit me-1"></i>แก้ไข
            </button>
        </div>
        <div class="info-row">
            <span class="info-label">Username</span>
            <span class="info-val">@Model.Username</span>
        </div>
        <div class="info-row">
            <span class="info-label">ชื่อ-นามสกุล</span>
            <span class="info-val">@(Model.FullName ?? "-")</span>
        </div>
        <div class="info-row">
            <span class="info-label">เพศ</span>
            <span class="info-val">@(Model.Userprofile?.Gender ?? "-")</span>
        </div>
        <div class="info-row">
            <span class="info-label">วันเกิด</span>
            <span class="info-val">@(Model.Userprofile?.Birthday?.ToString("dd/MM/yyyy") ?? "-")</span>
        </div>
        <div class="info-row">
            <span class="info-label">เบอร์โทร</span>
            <span class="info-val">@(Model.Userprofile?.Tel ?? "-")</span>
        </div>
        <div class="info-row">
            <span class="info-label">ที่อยู่จัดส่ง</span>
            <span class="info-val text-end" style="max-width:60%;">@(Model.Userprofile?.Address ?? "-")</span>
        </div>
    </div>

    @* ── Edit Form (ซ่อนไว้ก่อน) ── *@
    <div class="profile-card" id="editSection" style="display:none;">
        <div class="d-flex justify-content-between align-items-center mb-3">
            <h6 class="fw-bold mb-0"><i class="fas fa-edit me-2 text-warning"></i>แก้ไขข้อมูล</h6>
        </div>
        <form asp-controller="Project" asp-action="MyProfile" method="post">
            <input type="hidden" asp-for="Id" />
            <input type="hidden" asp-for="Userprofile.UserId" />
            <div class="mb-3">
                <label class="form-label small fw-semibold">ชื่อ-นามสกุล</label>
                <input asp-for="FullName" class="form-control" placeholder="ชื่อ-นามสกุล" required />
            </div>
            <div class="row g-3 mb-3">
                <div class="col-md-6">
                    <label class="form-label small fw-semibold">เพศ</label>
                    <select asp-for="Userprofile.Gender" class="form-control">
                        <option value="">-- ระบุเพศ --</option>
                        <option value="Male">ชาย</option>
                        <option value="Female">หญิง</option>
                    </select>
                </div>
                <div class="col-md-6">
                    <label class="form-label small fw-semibold">วันเกิด</label>
                    <input asp-for="Userprofile.Birthday" type="date" class="form-control" />
                </div>
            </div>
            <div class="mb-3">
                <label class="form-label small fw-semibold">เบอร์โทรศัพท์</label>
                <input asp-for="Userprofile.Tel" class="form-control" placeholder="08x-xxx-xxxx" />
            </div>
            <div class="mb-3">
                <label class="form-label small fw-semibold">ที่อยู่จัดส่ง</label>
                <textarea asp-for="Userprofile.Address" class="form-control" rows="2"
                          placeholder="ที่อยู่สำหรับจัดส่งสินค้า..."></textarea>
            </div>
            <div class="d-flex justify-content-end gap-2">
                <button type="button" class="btn btn-outline-secondary px-4"
                        onclick="toggleEdit(false)">ยกเลิก</button>
                <button type="submit" class="btn btn-warning fw-bold px-4 text-dark">
                    <i class="fas fa-save me-1"></i>บันทึก
                </button>
            </div>
        </form>
    </div>

    @* ── Membership ── *@
    <div class="profile-card">
        <h6 class="fw-bold mb-3"><i class="fas fa-crown me-2 text-warning"></i>สมาชิก</h6>
        @if (isMember)
        {
            <div class="member-card mb-3">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <div class="fw-bold" style="color:#f4c430;">MEMBER ACTIVE</div>
                        <div class="small" style="opacity:.75;">หมดอายุ @Model.MemberExpiry!.Value.ToString("dd MMM yyyy")</div>
                    </div>
                    <div style="font-size:2rem;">👑</div>
                </div>
                <div class="mt-2" style="background:rgba(255,255,255,.1);border-radius:8px;padding:6px 12px;display:inline-block;">
                    เหลือ <strong style="color:#f4c430;font-size:1.1rem;">@daysLeft</strong> วัน
                </div>
            </div>
        }
        else
        {
            <div class="member-card inactive mb-3">
                <div class="text-muted small mb-1">ยังไม่ได้เป็นสมาชิก</div>
                <div class="fw-semibold">Bronze Member (ฟรี)</div>
            </div>
        }
        <a asp-action="Upgrade" asp-controller="Project"
           class="btn btn-warning fw-bold w-100 text-dark">
            <i class="fas fa-crown me-1"></i>@(isMember ? "ต่ออายุ Member" : "สมัคร Member")
        </a>
    </div>

    @* ── Points ── *@
    <div class="profile-card">
        <h6 class="fw-bold mb-3"><i class="fas fa-coins me-2 text-warning"></i>แต้มสะสม</h6>
        <div class="points-badge mb-3 d-flex justify-content-between align-items-center">
            <div>
                <div style="font-size:1.8rem;font-weight:800;color:#f4c430;line-height:1;">@Model.Points</div>
                <div class="small text-muted">แต้ม = ส่วนลด ฿@(Model.Points / 10)</div>
            </div>
            <div class="text-muted small text-end">10 แต้ม = ฿1<br>ใช้ได้ตอนสั่งซื้อ</div>
        </div>
        @if (ViewBag.PointHistory is IEnumerable<_66044011_Tatsunori.Models.Pointhistory> hist && hist.Any())
        {
            <div class="small text-muted fw-semibold mb-2">ประวัติแต้มล่าสุด</div>
            @foreach (var p in hist.Take(5))
            {
                <div class="d-flex justify-content-between py-1" style="border-bottom:1px solid var(--border,#2a3a50);font-size:.82rem;">
                    <span class="text-muted">@p.CreatedAt.ToString("dd/MM/yy HH:mm")</span>
                    <span class="@(p.Points > 0 ? "text-success" : "text-danger") fw-semibold">
                        @{ var prefix = p.Points > 0 ? "+" : ""; }
                        @prefix@p.Points แต้ม
                    </span>
                </div>
            }
        }
    </div>

</div>

@section Scripts {
<script>
function toggleEdit(show) {
    document.getElementById('viewSection').style.display = show ? 'none' : 'block';
    document.getElementById('editSection').style.display = show ? 'block' : 'none';
    if (show) document.getElementById('editSection').scrollIntoView({behavior:'smooth', block:'start'});
}
</script>
}
