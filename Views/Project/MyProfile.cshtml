@model _66044011_Tatsunori.Models.User
@{
    ViewData["Title"] = "แก้ไขโปรไฟล์";
}

@section Styles {
<link rel="stylesheet" href="~/css/myProfile.css" asp-append-version="true">
}

<div class="profile-wrapper">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold mb-0"><i class="fas fa-user-edit me-2"></i>แก้ไขโปรไฟล์</h2>
            <small class="text-muted">อัปเดตข้อมูลส่วนตัวของคุณ</small>
        </div>
    </div>

    @if (TempData["ProfileSuccess"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show mb-4 py-2">
            <i class="fas fa-check-circle me-1"></i> @TempData["ProfileSuccess"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="form-container">
        <form asp-controller="Project" asp-action="MyProfile" method="post">
            <input type="hidden" asp-for="Id" />
            <input type="hidden" asp-for="Userprofile.UserId" />

            <div class="section-title">
                <i class="fas fa-lock"></i> ข้อมูลบัญชี (แก้ไขไม่ได้)
            </div>
            <div class="form-row">
                <div class="form-group">
                    <label>Username</label>
                    <input asp-for="Username" class="form-control" readonly />
                    <span class="readonly-note">ไม่สามารถเปลี่ยน Username ได้</span>
                </div>
                <div class="form-group">
                    <label>Email</label>
                    <input asp-for="Email" class="form-control" readonly />
                    <span class="readonly-note">ไม่สามารถเปลี่ยน Email ได้</span>
                </div>
            </div>

            <div class="section-title">
                <i class="fas fa-user"></i> ข้อมูลส่วนตัว
            </div>
            <div class="form-group">
                <label>ชื่อ-นามสกุล</label>
                <input asp-for="FullName" class="form-control" placeholder="ชื่อ-นามสกุล" required />
            </div>
            <div class="form-row">
                <div class="form-group">
                    <label>เพศ</label>
                    <select asp-for="Userprofile.Gender" class="form-control">
                        <option value="">-- ระบุเพศ --</option>
                        <option value="Male">ชาย</option>
                        <option value="Female">หญิง</option>
                    </select>
                </div>
                <div class="form-group">
                    <label>วันเกิด</label>
                    <input asp-for="Userprofile.Birthday" type="date" class="form-control" />
                </div>
            </div>
            <div class="form-row">
                <div class="form-group">
                    <label>เบอร์โทรศัพท์</label>
                    <input asp-for="Userprofile.Tel" class="form-control" placeholder="08x-xxx-xxxx" />
                </div>
                
            </div>
            <div class="form-group">
                <label>ที่อยู่จัดส่ง</label>
                <textarea asp-for="Userprofile.Address" class="form-control"
                          placeholder="ที่อยู่สำหรับจัดส่งสินค้า..."></textarea>
            </div>

            <div class="action-footer">
                <a asp-action="ProductList" asp-controller="Project"
                   class="btn btn-outline-secondary px-4">ยกเลิก</a>
                <button type="submit" class="btn-save">
                    <i class="fas fa-save"></i> บันทึก
                </button>
            </div>
        </form>
    </div>
</div>
