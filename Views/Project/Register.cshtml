@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="th">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Sign Up - STRIKE FORCE</title>
    <link href="https://fonts.googleapis.com/css2?family=Rajdhani:wght@400;600;700&family=Sarabun:wght@300;400;600&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css">
    <link rel="stylesheet" href="/css/register.css">
</head>
<body>
    <div class="register-container">
        <div class="register-header">
            <img src="/images/Logo.png" alt="Strike Force">
            <h2>สมัครสมาชิก</h2>
            <p><i class="fas fa-crosshairs"></i> STRIKE FORCE BB GUN & GEAR</p>
        </div>
        <div class="register-body">
            <div class="bronze-note">
                <i class="fas fa-crown"></i>
                <strong>สมัครได้เลย — เริ่มต้นที่ระดับ Bronze ฟรี!</strong><br>
                เมื่อสมัครแล้วสามารถกด <strong>Upgrade</strong> ที่ navbar เพื่อเลื่อนระดับเป็น Silver หรือ Gold ได้
            </div>

            @if (ViewBag.Error != null)
            {
                <p class="text-error"><i class="fas fa-exclamation-circle me-1"></i>@ViewBag.Error</p>
            }

            <form method="post" asp-controller="Project" asp-action="Register">
                <p class="section-label"><i class="fas fa-lock me-1"></i>ข้อมูลบัญชี</p>
                <div class="form-grid">
                    <div class="field">
                        <label>Username <span class="req">*</span></label>
                        <input type="text" name="Username" placeholder="ชื่อผู้ใช้" required>
                    </div>
                    <div class="field">
                        <label>Password <span class="req">*</span></label>
                        <input type="password" name="Password" placeholder="รหัสผ่าน" required>
                    </div>
                    <div class="field full">
                        <label>Email <span class="req">*</span></label>
                        <input type="email" name="Email" placeholder="example@mail.com" required>
                    </div>
                </div>

                <p class="section-label"><i class="fas fa-user me-1"></i>ข้อมูลส่วนตัว</p>
                <div class="form-grid">
                    <div class="field full">
                        <label>ชื่อ-นามสกุล <span class="req">*</span></label>
                        <input type="text" name="FullName" placeholder="ชื่อ-นามสกุล" required>
                    </div>
                    <div class="field">
                        <label>เพศ <span class="req">*</span></label>
                        <select name="Gender" required>
                            <option value="" disabled selected>เลือกเพศ</option>
                            <option value="Male">ชาย</option>
                            <option value="Female">หญิง</option>
                        </select>
                    </div>
                    <div class="field">
                        <label>วันเกิด <span class="req">*</span></label>
                        <input type="date" name="Birthday" required>
                    </div>
                    <div class="field full">
                        <label>เบอร์โทรศัพท์ <span class="req">*</span></label>
                        <input type="tel" name="Phone" placeholder="08X-XXX-XXXX" required>
                    </div>
                    <div class="field full">
                        <label>ที่อยู่จัดส่ง</label>
                        <textarea name="Address" placeholder="บ้านเลขที่ ถนน แขวง/ตำบล เขต/อำเภอ จังหวัด รหัสไปรษณีย์"></textarea>
                    </div>
                </div>

                <button type="submit" class="register-btn">
                    <i class="fas fa-user-plus me-1"></i>สมัครสมาชิก
                </button>
            </form>
            <p class="login-link">มีบัญชีแล้ว? <a asp-action="Login" asp-controller="Project">เข้าสู่ระบบ</a></p>
        </div>
    </div>
</body>
</html>