@model IEnumerable<_66044011_Tatsunori.Models.Order>
@{
    Layout = "_HeaderFoot";
    ViewData["Title"] = "รายงานยอดขาย";
}

@section Styles {
<style>
    .report-wrapper { max-width: 1100px; margin: 0 auto; }
    .period-tabs { display: flex; gap: 8px; margin-bottom: 24px; }
    .period-btn {
        padding: 8px 20px; border-radius: 20px; border: 1px solid #ddd;
        background: #fff; font-weight: 600; font-size: .85rem;
        cursor: pointer; text-decoration: none; color: #555; transition: .2s;
    }
    .period-btn:hover, .period-btn.active {
        background: #1a1a1a; color: #fff; border-color: #1a1a1a;
    }
    .kpi-bar { display: flex; gap: 16px; margin-bottom: 24px; flex-wrap: wrap; }
    .kpi-card {
        background: #fff; border-radius: 12px; border: 1px solid #eee;
        padding: 20px 24px; flex: 1; min-width: 180px;
        box-shadow: 0 2px 8px rgba(0,0,0,.04); position: relative; overflow: hidden;
    }
    .kpi-val { font-size: 2rem; font-weight: 700; color: #1a1a1a; }
    .kpi-lbl { font-size: .78rem; color: #adb5bd; text-transform: uppercase; margin-top: 4px; }
    .kpi-icon { font-size: 2.5rem; opacity: .08; position: absolute; right: 16px; top: 16px; }
    .report-card {
        background: #fff; border-radius: 12px; border: 1px solid #eee;
        box-shadow: 0 2px 8px rgba(0,0,0,.04); overflow: hidden; margin-bottom: 24px;
    }
    .report-card-header {
        background: #1a1a1a; color: #fff;
        padding: 14px 20px; font-weight: 700; font-size: .95rem;
    }
    .report-card th {
        background: #f8f9fa; padding: 12px 16px;
        font-size: .82rem; font-weight: 600; color: #6c757d;
        border-bottom: 2px solid #eee;
    }
    .report-card td {
        padding: 12px 16px; vertical-align: middle;
        border-bottom: 1px solid #f5f5f5;
    }
    .report-card tr:last-child td { border-bottom: none; }
    .status-badge { padding: 4px 10px; border-radius: 20px; font-size: .75rem; font-weight: 700; }
    .badge-Pending  { background: #fff3cd; color: #856404; }
    .badge-Paid     { background: #d1e7dd; color: #0f5132; }
    .badge-Shipped  { background: #cff4fc; color: #055160; }
    .bar-track { background: #f0f0f0; border-radius: 4px; height: 8px; }
    .bar-fill  { background: #1a1a1a; border-radius: 4px; height: 8px; transition: width .5s; }
</style>
}

<div class="report-wrapper">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold mb-0"><i class="fas fa-chart-bar me-2"></i>รายงานยอดขาย</h2>
            <small class="text-muted">
                @((DateTime)ViewBag.Start).ToString("dd/MM/yyyy") —
                @((DateTime)ViewBag.End).ToString("dd/MM/yyyy")
            </small>
        </div>
    </div>

    <div class="period-tabs">
        <a asp-action="SalesReport" asp-controller="Project" asp-route-period="daily"
           class="period-btn @(ViewBag.Period == "daily" ? "active" : "")">
            <i class="fas fa-calendar-day me-1"></i>วันนี้
        </a>
        <a asp-action="SalesReport" asp-controller="Project" asp-route-period="monthly"
           class="period-btn @(ViewBag.Period == "monthly" ? "active" : "")">
            <i class="fas fa-calendar-alt me-1"></i>เดือนนี้
        </a>
        <a asp-action="SalesReport" asp-controller="Project" asp-route-period="yearly"
           class="period-btn @(ViewBag.Period == "yearly" ? "active" : "")">
            <i class="fas fa-calendar me-1"></i>ปีนี้
        </a>
    </div>

    <div class="kpi-bar">
        <div class="kpi-card">
            <i class="fas fa-shopping-bag kpi-icon"></i>
            <div class="kpi-val text-primary">@ViewBag.TotalOrders</div>
            <div class="kpi-lbl">ออเดอร์ทั้งหมด</div>
        </div>
        <div class="kpi-card">
            <i class="fas fa-box kpi-icon"></i>
            <div class="kpi-val text-success">@ViewBag.TotalItems</div>
            <div class="kpi-lbl">สินค้าที่ขายได้ (ชิ้น)</div>
        </div>
        <div class="kpi-card">
            <i class="fas fa-dollar-sign kpi-icon"></i>
            <div class="kpi-val" style="color:#f39c12;">
                ฿@((decimal)ViewBag.TotalRevenue).ToString("N0")
            </div>
            <div class="kpi-lbl">รายได้รวม</div>
        </div>
        <div class="kpi-card">
            <i class="fas fa-receipt kpi-icon"></i>
            <div class="kpi-val">
                @if ((int)ViewBag.TotalOrders > 0)
                {
                    @((((decimal)ViewBag.TotalRevenue) / (int)ViewBag.TotalOrders).ToString("N0"))
                }
                else { @("0") }
            </div>
            <div class="kpi-lbl">เฉลี่ย/ออเดอร์ (฿)</div>
        </div>
    </div>

    <div class="row g-4 mb-4">
        <div class="col-lg-5">
            <div class="report-card">
                <div class="report-card-header">
                    <i class="fas fa-trophy me-2"></i>สินค้าขายดี Top 5
                </div>
                <div class="p-3">
                @{
                    var tops   = (dynamic)ViewBag.TopProducts;
                    decimal maxRev = 0;
                    foreach (var t in tops)
                    {
                        if ((decimal)t.Revenue > maxRev) maxRev = (decimal)t.Revenue;
                    }
                }
                @foreach (var t in tops)
                {
                    decimal pct = maxRev > 0 ? ((decimal)t.Revenue / maxRev) * 100 : 0;
                    <div class="mb-3">
                        <div class="d-flex justify-content-between mb-1">
                            <span class="fw-semibold small">@t.Name</span>
                            <span class="text-muted small">
                                ฿@((decimal)t.Revenue).ToString("N0") (@t.Qty ชิ้น)
                            </span>
                        </div>
                        <div class="bar-track">
                            <div class="bar-fill" style="width:@pct%"></div>
                        </div>
                    </div>
                }
                </div>
            </div>
        </div>

        <div class="col-lg-7">
            <div class="report-card">
                <div class="report-card-header">
                    <i class="fas fa-list me-2"></i>รายการออเดอร์
                </div>
                <div style="max-height:340px; overflow-y:auto;">
                    <table class="table mb-0">
                        <thead>
                            <tr>
                                <th>#</th>
                                <th>วันที่</th>
                                <th>ลูกค้า</th>
                                <th class="text-end">ยอด</th>
                                <th class="text-center">สถานะ</th>
                            </tr>
                        </thead>
                        <tbody>
                        @foreach (var o in Model)
                        {
                            <tr>
                                <td class="small fw-bold">#@o.OrderId</td>
                                <td class="small text-muted">
                                    @o.OrderDate?.ToString("dd/MM/yy HH:mm")
                                </td>
                                <td class="small">
                                    @(o.User?.FullName ?? o.User?.Username)
                                </td>
                                <td class="small text-end fw-bold text-primary">
                                    ฿@o.TotalAmount.ToString("N0")
                                </td>
                                <td class="text-center">
                                    <span class="status-badge badge-@o.Status">@o.Status</span>
                                </td>
                            </tr>
                        }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>