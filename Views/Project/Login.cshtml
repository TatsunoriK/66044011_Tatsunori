@{
    Layout = null;
}
@model _66044011_Tatsunori.ViewModels.LoginViewModels
<!DOCTYPE html>
<html lang="th">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Login - STRIKE FORCE</title>
    <link href="https://fonts.googleapis.com/css2?family=Rajdhani:wght@400;600;700&family=Sarabun:wght@300;400;600&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css">
    <link rel="stylesheet" href="/css/login.css">
</head>
<body>
    <div class="left-side">
        <!-- Grid overlay -->
        <div class="grid-overlay"></div>
        <!-- Animated beams -->
        <div class="beam beam-1"></div>
        <div class="beam beam-2"></div>
        <div class="beam beam-3"></div>
        <div class="beam beam-4"></div>
        <div class="beam beam-5"></div>
        <div class="beam beam-6"></div>
        <!-- Glow orbs -->
        <div class="orb orb-1"></div>
        <div class="orb orb-2"></div>
        <div class="orb orb-3"></div>

        <!-- Brand content -->
        <div class="left-content">
            <div class="brand-logo">
                <img src="/images/Logo.png" alt="Strike Force">
            </div>
            <h1 class="brand-title">STRIKE FORCE</h1>
            <p class="brand-sub">PREMIUM BB GUN & GEAR</p>
            <div class="brand-divider"></div>
            <div class="feature-list">
                <div class="feature-item">
                    <span class="feat-icon"><i class="fas fa-bolt"></i></span>
                    <div>
                        <div class="feat-title">Flash Sale</div>
                        <div class="feat-desc">โปรโมชันพิเศษจำกัดเวลา</div>
                    </div>
                </div>
                <div class="feature-item">
                    <span class="feat-icon"><i class="fas fa-crown"></i></span>
                    <div>
                        <div class="feat-title">Member Exclusive</div>
                        <div class="feat-desc">ส่วนลดและสิทธิพิเศษสำหรับสมาชิก</div>
                    </div>
                </div>
                <div class="feature-item">
                    <span class="feat-icon"><i class="fas fa-coins"></i></span>
                    <div>
                        <div class="feat-title">Point Rewards</div>
                        <div class="feat-desc">สะสมแต้มแลกส่วนลดได้เลย</div>
                    </div>
                </div>
            </div>
        </div>


    </div>

    <div class="divider"></div>

    <div class="right-side">
        <div class="login-box">
            <img src="/images/Logo.png" alt="Strike Force" class="logo">
            <h1>Login</h1>

            @if (ViewBag.Error != null)
            {
                <p class="text-error"><i class="fas fa-exclamation-circle me-1"></i>@ViewBag.Error</p>
            }

            <form asp-action="Login" asp-controller="Project" method="post">
                <div class="input-group">
                    <i class="fas fa-user input-icon"></i>
                    <input type="text" asp-for="UserId" placeholder="Username" required>
                </div>
                <div class="input-group">
                    <i class="fas fa-lock input-icon"></i>
                    <input type="password" asp-for="Password" placeholder="Password" required>
                </div>
                <button type="submit" class="login-btn">
                    <span>LOGIN</span>
                    <i class="fas fa-arrow-right ms-2"></i>
                </button>
            </form>

            <p class="signup-text">
                Don't have an account?
                <a asp-action="Register" asp-controller="Project">Sign Up</a>
            </p>
        </div>
    </div>
</body>
</html>
