@{
    Layout = null;
}
@model _66044011_Tatsunori.ViewModels.LoginViewModels
<!DOCTYPE html>
<html lang="th">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Login - STRIKE FORCE</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css">
    <link rel="stylesheet" href="/css/login.css">
</head>
<body>
    <div class="left-side"></div>
    <div class="divider"></div>
    <div class="right-side">
        <div class="login-box">
            <img src="/images/Logo.png" alt="Strike Force" class="logo">
            <h1>Login</h1>

            @if (ViewBag.Error != null)
            {
                <p class="text-error"><i class="fas fa-exclamation-circle me-1"></i>@ViewBag.Error</p>
            }

            <form asp-action="Login" asp-controller="Project" method="post">
                <div class="input-group">
                    <input type="text" asp-for="UserId" placeholder="Username" required>
                </div>
                <div class="input-group">
                    <input type="password" asp-for="Password" placeholder="Password" required>
                </div>
                <button type="submit" class="login-btn">Login</button>
            </form>

            <p class="signup-text">
                Don't have an account?
                <a asp-action="Register" asp-controller="Project">Sign Up</a>
            </p>
        </div>
    </div>
</body>
</html>
