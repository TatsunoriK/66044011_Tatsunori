@model IEnumerable<_66044011_Tatsunori.Models.User>
@{
    ViewData["Title"] = "จัดการระบบ";
}

@section Styles {
    <link rel="stylesheet" href="~/css/management.css" asp-append-version="true">
}

<div class="manage-wrapper">

    <div class="manage-header">
        <div>
            <h2 class="fw-bold mb-0">Employee List</h2>
            <p class="text-muted small">จัดการข้อมูลและสิทธิ์การเข้าถึงของพนักงานทั้งหมด</p>
        </div>
        <div class="d-flex align-items-center gap-3">
            <div class="emp-count-box">
                <span class="emp-count-label">Total Employees</span>
                <span class="emp-count-val">@Model.Count()</span>
            </div>
            <button class="btn btn-dark px-4 py-2 fw-bold" data-bs-toggle="modal" data-bs-target="#addStaffModal">
                <i class="fas fa-user-plus me-2"></i>เพิ่มพนักงาน
            </button>
        </div>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success fw-semibold">@TempData["Success"]</div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger fw-semibold">@TempData["Error"]</div>
    }

    <div class="table-card">
        <table class="manage-table">
            <thead>
                <tr>
                    <th>ID</th>
                    <th>Full Name</th>
                    <th>Gender</th>
                    <th>Birth Date</th>
                    <th>Tel</th>
                    <th>Role</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var user in Model)
                {
                    <tr>
                        <td>#@user.Id</td>
                        <td>
                            <div class="user-cell">
                                <img src="https://ui-avatars.com/api/?name=@Uri.EscapeDataString(user.FullName ?? "User")&background=000&color=fff" class="avatar">
                                <div>
                                    <div class="fw-bold">@(user.FullName ?? "-")</div>
                                    <div class="text-muted small">@(user.Email ?? "-")</div>
                                </div>
                            </div>
                        </td>
                        <td>@(user.Userprofile?.Gender ?? "-")</td>
                        <td>@(user.Userprofile?.Birthday?.ToString("dd MMM yyyy") ?? "-")</td>
                        <td>@(user.Userprofile?.Tel ?? "-")</td>
                        <td>
                            <form asp-controller="Project" asp-action="ChangeRole" method="post">
                                <input type="hidden" name="userId" value="@user.Id" />
                                <select name="roleId" onchange="this.form.submit()" class="form-select form-select-sm">
                                    @{ var rid = user.RoleId; }
                                    @if (rid == 1) { <option value="1" selected>Admin</option> } else { <option value="1">Admin</option> }
                                    @if (rid == 2) { <option value="2" selected>Manager</option> } else { <option value="2">Manager</option> }
                                    @if (rid == 3) { <option value="3" selected>Staff</option> } else { <option value="3">Staff</option> }
                                    @if (rid == 4) { <option value="4" selected>Customer</option> } else { <option value="4">Customer</option> }
                                </select>
                            </form>
                        </td>
                        <td class="action-cell">
                            <a asp-controller="Project" asp-action="EditUser" asp-route-id="@user.Id" title="Edit">✏️</a>
                            @if (user.Id != (int)(ViewBag.CurrentId ?? 0))
                            {
                                <a asp-controller="Project" asp-action="DeleteUser" asp-route-id="@user.Id"
                                   onclick="return confirm('ลบผู้ใช้ @(user.FullName ?? user.Username)?')"
                                   title="Delete">🗑️</a>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

</div>

{{*  ===== ADD STAFF MODAL ===== *}}
<div class="modal fade" id="addStaffModal" tabindex="-1" aria-labelledby="addStaffModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content" style="border-radius:16px; overflow:hidden;">

            <div class="modal-header" style="background:#111; color:#fff; border:none;">
                <h5 class="modal-title fw-bold" id="addStaffModalLabel">
                    <i class="fas fa-user-plus me-2 text-warning"></i>เพิ่มพนักงานใหม่
                </h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>

            <div class="modal-body p-4">
                @if (TempData["AddStaffError"] != null)
                {
                    <div class="alert alert-danger">@TempData["AddStaffError"]</div>
                }

                <form method="post" asp-controller="Project" asp-action="AddStaff">
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="form-label fw-semibold">Username <span class="text-danger">*</span></label>
                            <input type="text" name="Username" class="form-control" placeholder="ชื่อผู้ใช้" required>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-semibold">Password <span class="text-danger">*</span></label>
                            <input type="password" name="Password" class="form-control" placeholder="รหัสผ่าน" required>
                        </div>
                        <div class="col-12">
                            <label class="form-label fw-semibold">Email <span class="text-danger">*</span></label>
                            <input type="email" name="Email" class="form-control" placeholder="example@mail.com" required>
                        </div>
                        <div class="col-12">
                            <label class="form-label fw-semibold">Full Name <span class="text-danger">*</span></label>
                            <input type="text" name="FullName" class="form-control" placeholder="ชื่อ-นามสกุล" required>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label fw-semibold">Gender</label>
                            <select name="Gender" class="form-select">
                                <option value="" disabled selected>เลือกเพศ</option>
                                <option value="Male">ชาย</option>
                                <option value="Female">หญิง</option>
                            </select>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label fw-semibold">Birthday</label>
                            <input type="date" name="Birthday" class="form-control">
                        </div>
                        <div class="col-md-4">
                            <label class="form-label fw-semibold">Phone</label>
                            <input type="tel" name="Phone" class="form-control" placeholder="08X-XXX-XXXX">
                        </div>
                        <div class="col-12">
                            <label class="form-label fw-semibold">ตำแหน่ง <span class="text-danger">*</span></label>
                            <select name="RoleId" class="form-select" required>
                                <option value="" disabled selected>-- เลือกตำแหน่ง --</option>
                                <option value="2">Manager</option>
                                <option value="3">Staff</option>
                            </select>
                        </div>
                    </div>

                    <div class="d-flex justify-content-end gap-2 mt-4">
                        <button type="button" class="btn btn-outline-secondary px-4" data-bs-dismiss="modal">ยกเลิก</button>
                        <button type="submit" class="btn btn-dark px-4 fw-bold">
                            <i class="fas fa-user-plus me-1"></i>เพิ่มพนักงาน
                        </button>
                    </div>
                </form>
            </div>

        </div>
    </div>
</div>
